<section class="featured-collection container" style="margin-bottom:var(--spacing-sections);">
  <div class="section-heading text-{{ section.settings.heading_align }}">
    {% if section.settings.heading != blank %}<h2 class="heading-font">{{ section.settings.heading }}</h2>{% endif %}
    {% if section.settings.subheading != blank %}<p class="section-subheading">{{ section.settings.subheading }}</p>{% endif %}
  </div>

  {% assign coll = collections[section.settings.collection] %}
  <div class="product-grid" style="--cols:{{ section.settings.products_per_row }};">
    {% if coll != blank %}
      {% for product in coll.products limit: section.settings.products_to_show %}
        {% unless product.tags contains 'hide-from-store' %}
          {% render 'product-card', product: product %}
        {% endunless %}
      {% endfor %}
    {% else %}
      {% for i in (1..section.settings.products_to_show) %}
        {% render 'product-card', product: blank %}
      {% endfor %}
    {% endif %}
  </div>

  {% if section.settings.show_view_all and coll != blank %}
    <div class="section-cta text-center">
      <a href="{{ coll.url }}" class="btn btn-secondary">View all</a>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured products" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "select", "id": "heading_align", "label": "Heading alignment", "options": [
        { "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }
      ], "default": "center" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "label": "Products to show", "default": 8 },
    { "type": "range", "id": "products_per_row", "min": 2, "max": 5, "step": 1, "label": "Products per row", "default": 4 },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'View all' button", "default": true }
  ],
  "presets": [ { "name": "Featured collection" } ]
}
{% endschema %}
