<style>
.compare-models-wrapper {
  overflow-x: auto;
}
.rwo-titel-text img {
    margin: 0 !important;
}
.compare-models-table { 
    border-collapse: collapse; 
    margin: 40px auto;
}
.compare-models-table .header-row {
    font-weight: bold;
    border-bottom: 1px solid #e0e0e0;
    background:none;
}
  tr:nth-child(odd) {
  background-color: #F5F5F5;   
  border-radius:70px;
}
.compare-models-table th,
.compare-models-table td { 
  padding: 15px;
  text-align: center;
  vertical-align: middle;
}
.product-header .price {
    font-size: 14px;
}
.compare-models-table th {
  background-color: #f9f9f9;
  font-weight: bold;
}

.compare-models-table td img {
  max-width: 100px;
  height: auto;
  display: block;
  margin: 0 auto;
}

.compare-models-table .row-title {
  text-align: left;
  font-weight: bold; 
}

.product-header .product-title {
    font-size: 14px;
}
  .column-text-pro {
    font-size: 12px;
    text-align: center;
}
.rwo-titel-text {
    font-size: 14px;
    font-weight: bold !important;
    display: flex;
    justify-content: flex-start;
    gap: 11px;
}
.header-row-text {
    font-size: 48px;
    text-align: left;
    line-height: 60px;
}
  
.compare-models-table .price {
  display: block;
}

.compare-models-table .original-price {
  text-decoration: line-through;
  color: #999;
}

.compare-models-table .header-row {
  font-weight: bold;
}

.compare-models-table .checkbox-cell {
  color: green;
  font-size: 20px;
}

.compare-models-table .checkbox-cell.false {
  color: red;
}

.compare-models-table .product-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.compare-models-table .product-header img {
  max-height: 80px;
  width: auto;
}

.compare-models-table .product-title {
  font-weight: bold;
  margin-bottom: 5px;
}


@media screen and (max-width: 992px) {

  .header-row-text {
    font-size: 26px;
    text-align: left;
    line-height: 40px;
}
  }

  @media screen and (max-width: 767px) {

  .header-row-text {
    font-size: 20px;
    line-height: 30px;
}
    .rwo-titel-text {
    font-size: 12px; 
}
  }
</style>

<section class="compare-models-section page-width">
  <div class="compare-models-wrapper">
    <table class="compare-models-table">
      <tbody>
        {% for block in section.blocks %}
          {% if block.type == 'header_row' %}
            <tr class="header-row">
              <td> <h4 class="header-row-text"> {{ block.settings.header_text }} </h4> </td>
              {% for i in (1..5) %}
                {% assign product_key = 'product_' | append: i %}
                {% assign product = all_products[block.settings[product_key]] %}
                <td>
                  {% if product %}
                    <div class="product-header">
                      {% if product.featured_image %}
                        {{ product.featured_image | image_url: width: 150 | image_tag: alt: product.title, class: 'product-image' }}
                      {% endif %}
                      <div class="product-title">{{ product.title }}</div>
                      <div class="price">
                        {% if product.compare_at_price > product.price %}
                          <span class="original-price">{{ product.compare_at_price | money }}</span>
                        {% endif %}
                        {{ product.price | money }}
                      </div>
                    </div>
                  {% else %}
                    {% assign header_text_key = 'header_text_' | append: i %}
                    {{ block.settings[header_text_key] }}
                  {% endif %}
                </td>
              {% endfor %}
            </tr>
          {% elsif block.type == 'text_row' %}
            <tr>
              <td class="row-title"> <h4 class="rwo-titel-text">  <img src="https://cdn.shopify.com/s/files/1/0897/8953/0400/files/question-mark-kdn.svg?v=1747900613" > {{ block.settings.row_title }} </h4> </td>
              {% for i in (1..5) %}
                {% assign text_key = 'text_' | append: i %}
                <td> <p class="column-text-pro"> {{ block.settings[text_key] }} </p> </td>
              {% endfor %}
            </tr>
          {% elsif block.type == 'checkbox_row' %}
            <tr>
              <td class="row-title"> <h4 class="rwo-titel-text"> <img src="https://cdn.shopify.com/s/files/1/0897/8953/0400/files/question-mark-kdn.svg?v=1747900613" > {{ block.settings.row_title }} </h4> </td>
              {% for i in (1..5) %}
                {% assign checkbox_key = 'checkbox_' | append: i %}
                <td class="checkbox-cell {{ block.settings[checkbox_key] }}">
                  {% if block.settings[checkbox_key] %}
                    <img src="https://cdn.shopify.com/s/files/1/0897/8953/0400/files/Vector_1.svg?v=1747892500" class="tick">
                  {% else %}
                    ✗
                  {% endif %}
                </td>
              {% endfor %}
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

