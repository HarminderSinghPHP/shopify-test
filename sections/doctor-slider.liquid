<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tiny-slider/2.9.2/tiny-slider.css">
<section id="calinicallyMainsection">
    <div class="container">
      <div class="simple-slider-section8788y">
        <h2 class="simple-slider-heading title h3">{{ section.settings.heading }}</h2>
        <div class="simple-slider-wrapper">
          <button type="button" class="simple-slider-button simple-slider-button--prevnew">&#8592;</button>
          <div class="simple-slider-containernew">
            <ul class="simple-slider-listnew">
              {% for block in section.blocks %}
              <li class="simple-slider-itemnew">
                <div class="simple-product-card">
                  <div class="simple-product-card__image-wrapper">
                    <img class="simple-product-card__image" src="{{ block.settings.doctor_image | img_url: '500x' }}" alt="{{ block.settings.doctor_name | escape }}">
                  </div>
                  <div class="simple-product-card__info">
                    <div class="simple-product-card__title">
                      <p>{{ block.settings.testimonial_text }}</p>
                    </div>
                    <div class="simple-product-card__price">
                      <p><strong>{{ block.settings.doctor_name }}</strong><br>{{ block.settings.doctor_specialty }}</p>
                    </div>
                  </div>
                </div>
              </li>
              {% endfor %}
            </ul>
          </div>
          <div class="slider-progress">
            <div class="slider-progress-barnew"></div>
          </div>
          <button type="button" class="simple-slider-button simple-slider-button--nextnew">&#8594;</button>
        </div>
      </div>
    </div>
  </section>

  <script>
    const sliderContainernew = document.querySelector('.simple-slider-containernew');
    const sliderListnew = document.querySelector('.simple-slider-listnew');
    const prevBtnnew = document.querySelector('.simple-slider-button--prevnew');
    const nextBtnnew = document.querySelector('.simple-slider-button--nextnew');
    const progressBarnew = document.querySelector('.slider-progress-barnew');

    function getitemWidthnew() {
      const item = document.querySelector('.simple-slider-itemnew');
      const style = getComputedStyle(item);
      const width = item.offsetWidth;
      const gap = parseInt(style.marginRight) || 20;
      return width + gap;
    }

    let itemWidthnew = getitemWidthnew();

    prevBtnnew.addEventListener('click', () => {
      sliderContainernew.scrollBy({ left: -itemWidthnew, behavior: 'smooth' });
    });

    nextBtnnew.addEventListener('click', () => {
      sliderContainernew.scrollBy({ left: itemWidthnew, behavior: 'smooth' });
    });

    function updateprogressBarnew() {
      const scrollLeft = sliderContainernew.scrollLeft;
      const scrollWidth = sliderContainernew.scrollWidth - sliderContainernew.clientWidth;
      const progressPercent = (scrollLeft / scrollWidth) * 100;
      progressBarnew.style.width = `${progressPercent}%`;
    }

    sliderContainernew.addEventListener('scroll', updateprogressBarnew);

    window.addEventListener('load', () => {
      itemWidthnew = getitemWidthnew();
      updateprogressBarnew();
    });

    // Drag and touch scroll
    (function () {
      let isDown = false, startX, scrollLeft;

      sliderContainernew.addEventListener('mousedown', (e) => {
        isDown = true;
        startX = e.pageX - sliderContainernew.offsetLeft;
        scrollLeft = sliderContainernew.scrollLeft;
        e.preventDefault();
      });

      sliderContainernew.addEventListener('mouseup', () => isDown = false);
      sliderContainernew.addEventListener('mouseleave', () => isDown = false);

      sliderContainernew.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        const x = e.pageX - sliderContainernew.offsetLeft;
        const walk = (x - startX) * 1.2;
        sliderContainernew.scrollLeft = scrollLeft - walk;
      });

      sliderContainernew.addEventListener('touchstart', (e) => {
        isDown = true;
        startX = e.touches[0].pageX - sliderContainernew.offsetLeft;
        scrollLeft = sliderContainernew.scrollLeft;
      });

      sliderContainernew.addEventListener('touchend', () => isDown = false);

      sliderContainernew.addEventListener('touchmove', (e) => {
        if (!isDown) return;
        const x = e.touches[0].pageX - sliderContainernew.offsetLeft;
        const walk = (x - startX) * 1.2;
        sliderContainernew.scrollLeft = scrollLeft - walk;
      });
    })();
  </script>

{% schema %}
{
  "name": "Doctor Testimonial Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Clinically-Backed. Doctor-Approved."
    }
  ],
  "blocks": [
    {
      "type": "doctor_testimonial",
      "name": "Doctor Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "doctor_image",
          "label": "Doctor Image"
        },
        {
          "type": "text",
          "id": "testimonial_text",
          "label": "Testimonial Text",
          "default": "“You can tell this was built with actual patient care in mind. It's not just a wellness gimmick—it's medically grounded.”"
        },
        {
          "type": "text",
          "id": "doctor_name",
          "label": "Doctor Name",
          "default": "Dr. Brian K."
        },
        {
          "type": "text",
          "id": "doctor_specialty",
          "label": "Doctor Specialty",
          "default": "Cardiologist"
        }
      ]
    }
  ],
  "presets": [
