<!-- sections/faq-section.liquid -->

<section class="faq-text" id="{{ section.id }}">
  <div class="faq-display">
    <div class="faq-div1"> 
      <h1 class="faq-h1">{{ section.settings.heading }}</h1>
    </div>
    <div class="faq-div2">

 {% for block in section.blocks %}
          <div class="pluse-item pluse-itema">
                <div class="fqa-click ">
                  <h2>{{ block.settings.question }}</h2>
                </div>
                <div class="at-tab" style="display:none;">
                  <p>
                    {{ block.settings.answer }}
                  </p>
