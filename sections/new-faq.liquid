<section class="custom-faq-section">
  <div class="custom-faq-container">
    <div class="custom-faq-heading">
      <h2>{{ section.settings.heading }}</h2>
    </div>
    <div class="custom-faq-list">
      {% for block in section.blocks %}
        <div class="custom-faq-item" {{ block.shopify_attributes }}>
          <button class="custom-faq-question">
            <p>{{ block.settings.question }}</p>
            <span class="custom-faq-icon">
              <img src="{{ block.settings.icon | default: 'https://cdn.shopify.com/s/files/1/0897/8953/0400/files/Icon.svg?v=1747141292' }}" alt="icon">
            </span>
          </button>
          <div class="custom-faq-answer">{{ block.settings.answer }}</div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  const questions = document.querySelectorAll(".custom-faq-question");

  questions.forEach(question => {
    question.addEventListener("click", () => {
      question.classList.toggle("active");
      const answer = question.nextElementSibling;

      if (question.classList.contains("active")) {
        answer.style.maxHeight = answer.scrollHeight + "px";
        answer.classList.add("open");
      } else {
        answer.style.maxHeight = null;
        answer.classList.remove("open");
      }
    });
  });
</script>

{% schema %}
{
  "name": "FAQ Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Frequently Asked<br />Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What makes the Nature Saunas different from your other sauna lines?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Details about how Nature Saunas differ...</p>"
        },
        {
          "type": "url",
          "id": "icon",
          "label": "Custom Icon URL (optional)",
          "info": "Leave empty to use default icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Section",
      "category": "Custom",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "What makes the Nature Saunas different from your other sauna lines?",
            "answer": "<p>Details about how Nature Saunas differ...</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How much space do I need for installation?",
            "answer": "<p>Information about space requirements...</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What type of heating technology does the Nature Saunas use?",
            "answer": "<p>Details about the technology used...</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  .custom-faq-answer.open {
    height: auto !important;
    max-height: max-content !important;
  }
</style>