<div class="medical-banner-container w3_bg">
  <h3 class="real-review-h3">Real Reviews from <span class="d-md-block">Real Customers</span></h3>
  
  <div class="carousel-container">
    <div class="review-section owl-carousel">
      {% for block in section.blocks %}
        <div class="item new-real">
          <div class="testimonial-container">
            
            <div class="newtest-text">
              <div>
                <h5>★★★★★</h5>
                <p>
                  This Medical 6 plus sauna is everything advertised and more. Very well engineered and great looking as well. Easily assembled in an hour or so. Simple to use, quiet and roomy.
                </p>
              </div>
              
              <div class="reviewer">
                <p>{{ block.settings.client_name }}, <i class="fa fa-check-circle image-marka" aria-hidden="true"></i></p>
                <div class="location">{{ block.settings.client_locat }}</div>
              </div>
            </div>
            
            <div class="next-image">
              <img src="{{ block.settings.icon_img | image_url }}" alt="review_clientimg">
              <!-- <a href="products/medical-6" class="cta-button">SHOP MEDICAL 6 SAUNA →</a> -->
            </div>
            
          </div> 
        </div>
      {% endfor %}

      
    </div> <!-- .review-section -->
  </div> <!-- .carousel-container -->

  <div class="progressBar-b-wrapper">
    <div class="progressBar-b" id="progress-nine"></div>
  </div>
</div> <!-- .medical-banner-container -->


<!-- Scripts -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/OwlCarousel2/2.3.4/owl.carousel.min.js"></script>

<script>
  $(document).ready(function(){
    var $carousel = $(".review-section");

    // Start with 20%
    $('#progress-nine').css('width', '20%');

    // Progress steps after first 20%
    const steps = [30, 60, 100, 0, 20];

    $carousel.owlCarousel({
      stagePadding: 300,
      loop: true,
      margin: 0,
      nav: true,
      dots: false,
      responsive:{
        0:{ items:1, stagePadding: 0 },
        600:{ items:1 },
        800:{ items:2 },
        1000:{ items:1 }
      }
    });

    let progressIndex = 0;

    function updateProgress() {
      // Cycle through steps array
      $('#progress-nine').css('width', steps[progressIndex] + '%');
      progressIndex = (progressIndex + 1) % steps.length;
    }

    $carousel.on('changed.owl.carousel', updateProgress);
  });
</script>


