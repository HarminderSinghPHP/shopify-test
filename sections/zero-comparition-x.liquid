<section class="w3_bg medical3-v2a {{ section.settings.addclass }}">
  
    <div class="w3_bg">
    <div class="acc-bg-blue w3_bg">
            <div class="container w3_bg">
            <div class="feature-h-text collapsed w3_bg" data-toggle="collapse" data-target="#{{ section.id }}">
                <h4 class="head-a1">{{ section.settings.heading }} </h4>
                <i class="fa fa-angle-up head-arrow arrow-gray"></i>
            </div>
            </div>
        </div>
        <div id="{{ section.id }}" class="collapse in  w3_bg" style="margin-top:{{ section.settings.mtop }}px; margin-bottom:{{ section.settings.mbottom }}px" >
          
           {% for block in section.blocks %}
            
           {%  if block.type == 'image_right' %}
              <section class="full-part w3_bg {{ block.settings.addclass2 }}" id="section-block-{{ block.id }}">
                <div class="container">
                 <div class="w3_bg">
                    <div class="row w3_bg medicalbased right-side-flow mb-1-img new-view--{{ forloop.index }} {{ forloop.index }}">
                    
                       <div class="col-md-6 mobile-p-0 medicalbased-a w3_bg block-id-{{ block.id }}" id="text-column-5">

                          {%  if block.settings.heading_r != blank %}
                         <h5 class="nature_padding_row font-style skin-reju"> 
                           {{ block.settings.heading_r }} 
                         </h5>
                         {% endif %}
                         
                         {{ block.settings.text_title_r }}

                          {%  if block.settings.heading2_r != blank %}
                         <h5 class="nature_padding_row font-style skin-reju">
                            {{ block.settings.heading2_r }}
                          </h5>
                         {% endif %}
                         
                           {{ block.settings.text_title2_r }}

                         {%  if block.settings.heading3_r != blank %}
                         <h5 class="nature_padding_row font-style skin-reju">
                            {{ block.settings.heading3_r }}
                          </h5>
                         {% endif %}
                           {{ block.settings.text_title3_r }}

                         {%  if block.settings.heading4_r != blank %}
                         <h5 class="nature_padding_row font-style skin-reju">
                            {{ block.settings.heading4_r }}
                          </h5>
                         {% endif %}
                           {{ block.settings.text_title4_r }}
                      </div>
                    
                     <div class="col-md-6 mobile-p-0  w3_bg block-id-{{ block.id }}" id="image-column-5">
                          <img width="" height="" 
                            src="{{ block.settings.feature_image_r | img_url: 'master' }}" 
                            alt="{{ block.settings.feature_image_r.alt }}"
                            class="rapid-img"
                            data-done="Loaded">
                      </div>

                    </div>
                  </div>
                </div>
              </section>
            {% endif %}


             
             
            {%  if block.type == 'image_left' %}
            <section class="full-part w3_bg {{ block.settings.addclass1 }}" id="section-block-{{ block.id }}">
              <div class="container">
                <div class="w3_bg">
                    <div class="row medicalbased left-side-flow mb-1-img w3_bg">
                        <div class="col-md-6 mobile-p-0 w3_bg" id="image-column-5">
                            <img width="" height="" 
                              src="{{ block.settings.feature_image_l | img_url: 'master' }}" 
                              alt="{{ block.settings.feature_image_l.alt }}" 
                              class="medical-rapidimg" 
                              html="" 
                              data-done="Loaded">
                        </div>                      
                        <div class="col-md-6 mobile-p-0 medicalbased-a w3_bg" id="text-column-5">

                          {%  if block.settings.heading_l != blank %}
                          <h5 class="nature_padding_row font-style skin-reju">
                            {{ block.settings.heading_l }}
                          </h5>
                          {% endif %}
                           {{ block.settings.text_title_l }}

                          {%  if block.settings.heading2_l != blank %}
                          <h5 class="nature_padding_row font-style skin-reju">
                            {{ block.settings.heading2_l }}
                          </h5>
                          {% endif %}
                           {{ block.settings.text_title2_l }}

                          {%  if block.settings.heading3_l != blank %}
                          <h5 class="nature_padding_row font-style skin-reju">
                            {{ block.settings.heading3_l }}
                          </h5>
                          {% endif %}
                           {{ block.settings.text_title3_l }}

                          {%  if block.settings.heading4_l != blank %}
                          <h5 class="nature_padding_row font-style skin-reju">
                            {{ block.settings.heading4_l }}
                          </h5>
                          {% endif %}
                           {{ block.settings.text_title4_l }}
                        </div>
                    </div>
                </div>
              </div>
              
            </section>
              {% endif %}

             {%  if block.type == 'text_only' %}
              <section class="full-part w3_bg {{ block.settings.addclass3 }}" id="section-block-{{ block.id }}">
                <div class="container">
                  <div class="col-md-12 mobile-p-0 w3_bg">
                      <h5 class="font-style hot-coldmedi">
                        {{ block.settings.heading }}
                      </h5>
                    
                     {{ block.settings.desc }}
                  </div>
                </div>
              </section>
            {% endif %}

             {%  if block.type == 'image_only' %}
               <section class="full-part w3_bg {{ block.settings.addclass4 }}" id="section-block-{{ block.id }}">
                 <div class="container">
                  <div class="col-md-12 mobile-p-0 w3_bg">
                  <picture>
                    <source media="(min-width:560px)" srcset="{{ block.settings.feature_image_only | img_url: 'master' }}">
                    <img src="{{ block.settings.feature_image_only | img_url: 'master' }}" 
                    data-src="{{ block.settings.feature_image_only | img_url: 'master' }}" 
                    alt="{{ block.settings.feature_image_only.alt }}"
                    class="img-responsive benefits-pd"
                    width=""
                    height=""
                    data-done="Loaded">
                    {%  if block.settings.mimage %}
                     <img class="mimageon" src="{{ block.settings.mimage | img_url: 'master' }}">
                    {% endif %}
                </picture>
                      
                  </div>
                 </div>
              </section>
                 
                {% endif %}
     
 {% endfor %}
          
        </div>
    </div>




<div class="container" id="icons-section">
   {% if section.settings.checked != blank %}  
   <div class=" custom_icons">
 {% for block in section.blocks %}
         
                     

 {%  if block.type == 'icon_block' %}
                              
                              <div class="icons">
                                <picture>
                                  <source media="(min-width:560px)" srcset="{{ block.settings.image | img_url: 'master' }}">
                                  <img 
                                    src="{{ block.settings.image | img_url: 'master' }}" 
                                    alt="{{ block.settings.image.alt }}" 
                                    class="img-responsive benefits-pd"
                                    data-done="Loaded">
                                </picture>
                            
                                <div class="multi_textcss">
                                  <h5><strong class="benefits_strong_h">{{ block.settings.title }}</strong></h5>
                                  <p>{{ block.settings.detail }}</p>
                                </div>
                              </div>
                             {% endif %}   
                      
                                     
            
   
  
    {% endfor %}
      </div> 
  {% endif %} 
    </div>




  
</section>




