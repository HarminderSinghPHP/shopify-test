  {%- style -%}
   .Inner-main .doctor-descrp{
     text-align: left;
   }



    @media screen and (max-width: 750px) {
      h4.medical-mainhead {
    margin: 5px 10px;
     }

      p.doctor-descrp {
 margin: 8px 10px;
}
      
    }
  {%- endstyle -%}


  
<div class="container">
  <div class="Inner-main">
      <div class="row">
        <div class="col-md-12 col-sm-12 col-xs-12 p-0" style="padding-top:10px; margin:0px;">
              {% if section.settings.medical-heading %}
                 <h4 class="medical-mainhead">
                  <strong style="color: #000; text-align: center; line-height: 1.3; text-align: justify;">{{ section.settings.medical-heading }}</strong>
                 </h4>
              {% endif %}
              {% if section.settings.medical-description1 %}
                <p class="doctor-descrp">{{ section.settings.medical-description1 }}</p>
              {% endif %}
              {% if section.settings.medical-description2 %}
                <p class="doctor-descrp">{{ section.settings.medical-description2 }}</p>
              {% endif %}
              {% if section.settings.medical-description3 %}
                <p class="doctor-descrp"><strong>{{ section.settings.medical-description3 }}</strong></p>
              {% endif %}
              {% if section.settings.medical-heading-img1 %}
                <img class="medical-deskimg" src="{{ section.settings.medical-heading-img1 | image_url }}" alt="">
              {% endif %}  
        </div>
    </div>
  </div>
</div>
{% schema %}
  {
    "name": "business-medical",
    "settings": [
        {
          "type": "textarea",
          "id": "medical-heading",
          "label": "Content "
        },
         {
          "type": "textarea",
          "id": "medical-description1",
          "label": "Content-description1 "
        },
         {
          "type": "textarea",
          "id": "medical-description2",
          "label": "Content-description1 "
        },
         {
          "type": "textarea",
          "id": "medical-description3",
          "label": "Content-description1 "
        },
         {
          "type": "image_picker",
          "id": "medical-heading-img1",
          "label": "Image"
        }
    ],
    "presets": [
    {
        "name":"business-medical"
    }
    ]
  }
{% endschema %}