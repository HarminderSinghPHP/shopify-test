<!-- sections/faq-section.liquid -->

<section class="faq-text" id="{{ section.id }}">
  <div class="faq-display">
    <div class="faq-div1"> 
      <h1 class="faq-h1">{{ section.settings.heading }}</h1>
    </div>
    <div class="faq-div2">
      <div class="panel-group" id="accordion-199" style="margin-top: 2rem;">
        
        {% for block in section.blocks %}
          <div class="panel faq-panel">
            <h4 class="faq-h2 panel-title-aa h4-panel padding-top-0 collapsed"
                data-toggle="collapse"
                data-parent="#accordion-199"
                href="#faq-{{ forloop.index }}"
                style="text-align: start; margin-top:0; margin-bottom:0;">
              {{ block.settings.question }}
              <a><span class="glyphicon"></span>
                <!-- <i class="fa fa-angle-down pull-right arrow-size9 rotate180"></i> -->
               <img class="faq-img" src="https://cdn.shopify.com/s/files/1/0897/8953/0400/files/Icon-FAQPLUSE_a847ce09-f97a-4da4-b436-7c6d3c8f90fd.png?v=1746453325" />
              </a>
            </h4>

            <div id="faq-{{ forloop.index }}" class="panel-collapse collapse {% if forloop.first %}{% endif %}" style="">
              <div>
                <p class="acordian-disc">{{ block.settings.answer }}</p>
              </div>
            </div>
          </div>
        {% endfor %}

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "faq-section-010525",
  "max_blocks": 25,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Main FAQ Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your return policy?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "We accept returns within 30 days of purchase."
        },
         {
          "type": "image_picker",
          "id": "faq-image",
          "label": "faq-image"
         },
      ]
    }
  ],
  "presets": [
    {
      "name": "faq-section-010525",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}
