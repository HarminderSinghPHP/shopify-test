<section class="container">
  <div class="iconboxsection">
    <div class="ibsheaading">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <div class="icon-boxes">
      {% for block in section.blocks %}
        <div class="iconbox{% cycle '1', '2' %}" {{ block.shopify_attributes }}>
          <h5>{{ block.settings.title }}</h5>
          <p style="text-align:left; margin-top:10px;">{{ block.settings.description }}</p>
          <div class="iconboxicon">
            {% if block.settings.icon %}
              <img src="{{ block.settings.icon | img_url: '100x' }}" alt="{{ block.settings.title | escape }}">
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .iconbox1 {
    /* Odd item styling */
    background: #f5f5f5; 
    padding: 20px;
    margin-bottom: 15px;
  }
  
  .iconbox2 { 
    background: #ffffff; 
    padding: 20px;
    margin-bottom: 15px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
  }
  
  .iconboxicon img {
    max-width: 50px;
    height: auto;
  }
  
  .ibsheaading {
    text-align: center;
    margin-bottom: 30px;
  }
  
  .icon-boxes {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  
  @media (min-width: 768px) {
    .icon-boxes {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Icon Grid Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clinically-Proven Health Benefits"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Backed by clinical research and developed with doctors, Medical Saunas™ are engineered to deliver measurable health improvements with every session."
    }
  ],
  "blocks": [
    {
      "type": "icon_box",
      "name": "Icon Box",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Feature description goes here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon Grid",
      "category": "Content",
      "blocks": [
        {
          "type": "icon_box",
          "settings": {
            "title": "Improved Circulation",
            "description": "Enhances blood flow throughout the body",
            "icon": "shopify:\/\/shop_images\/icon-circulation.png"
          }
        },
        {
          "type": "icon_box",
          "settings": {
            "title": "Muscle Recovery",
            "description": "Reduces recovery time after workouts",
            "icon": "shopify:\/\/shop_images\/icon-muscle.png"
          }
        },
        {
          "type": "icon_box",
          "settings": {
            "title": "Stress Relief",
            "description": "Promotes relaxation and reduces stress",
            "icon": "shopify:\/\/shop_images\/icon-stress.png"
          }
        },
        {
          "type": "icon_box",
          "settings": {
            "title": "Detoxification",
            "description": "Helps eliminate toxins through sweat",
            "icon": "shopify:\/\/shop_images\/icon-detox.png"
          }
        }
      ]
    }
  ]
}
{% endschema %}