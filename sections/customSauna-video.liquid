<section class="resort-one-spec" id="{{ section.id }}">
        <div class="acc-bg-blue">
            <div class="container">
            <div class="feature-h-text collapsed" data-toggle="collapse" data-target="#custom3-youtube">
                <h4 class="head-a1">Video of Custom<span> 3 Person Sauna</span> </h4>
                <i class="fa fa-angle-up head-arrow arrow-gray"></i>
            </div>
            </div>
        </div>
        <div class=" collapse in" id="custom3-youtube">
            <div class="resort-one-whiteaa">
                <div class="container paddinglr">
                    <iframe class="custom3youtube-video" src="https://www.youtube.com/embed/V20swuIi3n8?modestbranding=1&amp;autoplay=0&amp;rel=0&amp;controls=1&amp;mute=0" allowfullscreen="" frameborder="0"></iframe>
                </div>
            </div>
        </div>
        </section>
<style>
  #{{ section.id }} iframe.custom3youtube-video {
    width: 100%;
    height: 660px;
  }
 #{{ section.id }}  .resort-one-whiteaa {
    padding: 10px 0px 20px 0px;
}
 #{{ section.id }}  .head-a1 {
    text-align: left;
    font-size: 32px;
    width: 70%;
    padding-left: 0%;
    padding-bottom: 1%;
    padding-top: 1%;
    margin: 0%;
    color: #37b4ff !important;
    font-weight: bold;
    text-transform: uppercase;
}
  @media(max-width:767px){
  #{{ section.id }}  .head-a1 span {
    display: block;
    color: #fff;
    font-size: 20px;
}
  }
</style>
{% schema %}
  {
    "name": "Custom Sauna Video",
    "settings": [],
    "presets": [
      {
        "name": "Custom Sauna Video"
      }
    ]
  }
{% endschema %}