<section class="product-page container">
  <div class="product-layout">
    <div class="product-gallery">
      <div class="product-main-image" data-product-main-image>
        {% if product.featured_image %}
          <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.featured_image.alt | escape }}" id="ProductMainImage">
        {% else %}
          <div class="placeholder-media"></div>
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="product-thumbnails">
          {% for image in product.images %}
            <button class="product-thumb" data-thumb-src="{{ image | image_url: width: 1200 }}">
              <img src="{{ image | image_url: width: 200 }}" alt="{{ image.alt | escape }}">
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="product-info">
      {% if settings.show_vendor %}<p class="product-vendor">{{ product.vendor }}</p>{% endif %}
      <h1 class="product-title heading-font">{{ product.title }}</h1>

      <div class="product-price" data-product-price>
        {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
          <span class="price-compare" data-price-compare>{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
        {% else %}
          <span class="price-compare" data-price-compare hidden></span>
        {% endif %}
        <span class="price-current" data-price-current>{{ product.selected_or_first_available_variant.price | money }}</span>
      </div>

      <div class="product-description rte">{{ product.description }}</div>

      {% form 'product', product, class: 'product-form' %}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-id>

        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            {% assign option_index = forloop.index0 %}
            <div class="product-option" data-option-index="{{ option_index }}">
              <label {% if section.settings.variant_display == 'dropdown' %}for="ProductOption{{ option_index }}"{% endif %}>{{ option.name }}</label>

              {% if section.settings.variant_display == 'dropdown' %}
                <select class="option-select" id="ProductOption{{ option_index }}" data-option-index="{{ option_index }}">
                  {% for value in option.values %}
                    <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                  {% endfor %}
                </select>

              {% elsif section.settings.variant_display == 'cards' %}
                <div class="option-cards" data-option-index="{{ option_index }}">
                  {% for value in option.values %}
                    {% assign pack_block = null %}
                    {% for block in section.blocks %}
                      {% if block.type == 'pack_option' and block.settings.option_value == value %}
                        {% assign pack_block = block %}
                      {% endif %}
                    {% endfor %}

                    {% assign matched_variant = null %}
                    {% for v in product.variants %}
                      {% case option_index %}
                        {% when 0 %} {% assign v_opt = v.option1 %}
                        {% when 1 %} {% assign v_opt = v.option2 %}
                        {% when 2 %} {% assign v_opt = v.option3 %}
                      {% endcase %}
                      {% if v_opt == value and matched_variant == null %}
                        {% assign matched_variant = v %}
                      {% endif %}
                    {% endfor %}

                    <label class="option-card{% if option.selected_value == value %} is-selected{% endif %}" data-value="{{ value | escape }}">
                      <input type="radio" name="option-radio-{{ option_index }}" data-value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %}>

                      {% if pack_block and pack_block.settings.badge_text != blank %}
                        <span class="option-card-badge badge-{{ pack_block.settings.badge_style }}">{{ pack_block.settings.badge_text }}</span>
                      {% endif %}

                      <div class="option-card-body">
                        <div class="option-card-title-row">
                          <strong>{{ value }}</strong>
                          {% if matched_variant and pack_block and pack_block.settings.units_in_pack > 1 %}
                            {% assign units_f = pack_block.settings.units_in_pack | times: 1.0 %}
                            {% assign unit_price_cents = matched_variant.price | divided_by: units_f | round %}
                            <span class="option-card-each">{{ unit_price_cents | money }} each</span>
                          {% elsif matched_variant %}
                            <span class="option-card-each">{{ matched_variant.price | money }} each</span>
                          {% endif %}
                        </div>
                        {% if pack_block and pack_block.settings.subtitle != blank %}
                          <p class="option-card-subtitle">{{ pack_block.settings.subtitle }}</p>
                        {% endif %}
                      </div>

                      {% if matched_variant %}
                        <div class="option-card-price">
                          <div class="option-card-total">{{ matched_variant.price | money }}</div>
                          {% if matched_variant.compare_at_price > matched_variant.price %}
                            {% assign pack_savings = matched_variant.compare_at_price | minus: matched_variant.price %}
                            <div class="option-card-savings">Save {{ pack_savings | money }}</div>
                          {% endif %}
                        </div>
                      {% endif %}
                    </label>
                  {% endfor %}
                </div>


                 {% elsif section.settings.variant_display == 'card_with_img' %}
                <div class="option-cards" data-option-index="{{ option_index }}">
                  {% for value in option.values %}
                    {% assign pack_block = null %}
                    {% for block in section.blocks %}
                      {% if block.type == 'pack_option' and block.settings.option_value == value %}
                        {% assign pack_block = block %}
                      {% endif %}
                    {% endfor %}

                    {% assign matched_variant = null %}
                    {% for v in product.variants %}
                      {% case option_index %}
                        {% when 0 %} {% assign v_opt = v.option1 %}
                        {% when 1 %} {% assign v_opt = v.option2 %}
                        {% when 2 %} {% assign v_opt = v.option3 %}
                      {% endcase %}
                      {% if v_opt == value and matched_variant == null %}
                        {% assign matched_variant = v %}
                      {% endif %}
                    {% endfor %}

                    <label class="option-card{% if option.selected_value == value %} is-selected{% endif %}" data-value="{{ value | escape }}">
                      <input type="radio" name="option-radio-{{ option_index }}" data-value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %}>

                      {% if pack_block and pack_block.settings.badge_text != blank %}
                        <span class="option-card-badge badge-{{ pack_block.settings.badge_style }}">{{ pack_block.settings.badge_text }}</span>
                      {% endif %}

                      {% if matched_variant and matched_variant.featured_image %}
                        <img class="option-card-image" src="{{ matched_variant.featured_image | image_url: width: 40 }}" alt="{{ matched_variant.featured_image.alt | escape }}" loading="lazy">
                      {% endif %}

                      <div class="option-card-body">
                        <div class="option-card-title-row">
                          <strong>{{ value }}</strong>
                          {% if matched_variant and pack_block and pack_block.settings.units_in_pack > 1 %}
                            {% assign units_f = pack_block.settings.units_in_pack | times: 1.0 %}
                            {% assign unit_price_cents = matched_variant.price | divided_by: units_f | round %}
                            <span class="option-card-each">{{ unit_price_cents | money }} each</span>
                          {% elsif matched_variant %}
                            <span class="option-card-each">{{ matched_variant.price | money }} each</span>
                          {% endif %}
                        </div>
                        {% if pack_block and pack_block.settings.subtitle != blank %}
                          <p class="option-card-subtitle">{{ pack_block.settings.subtitle }}</p>
                        {% endif %}
                      </div>

                      {% if matched_variant %}
                        <div class="option-card-price">
                          <div class="option-card-total">{{ matched_variant.price | money }}</div>
                          {% if matched_variant.compare_at_price > matched_variant.price %}
                            {% assign pack_savings = matched_variant.compare_at_price | minus: matched_variant.price %}
                            <div class="option-card-savings">Save {{ pack_savings | money }}</div>
                          {% endif %}
                        </div>
                      {% endif %}
                    </label>
                  {% endfor %}
                </div>

              {% else %}
                <div class="option-values" data-option-index="{{ option_index }}">
                  {% for value in option.values %}
                    <button type="button" class="option-value{% if option.selected_value == value %} selected{% endif %}" data-value="{{ value | escape }}">{{ value }}</button>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        {% endunless %}

        <div class="product-quantity">
          <label for="Quantity">Quantity</label>
          <input type="number" id="Quantity" name="quantity" value="1" min="1">
        </div>

        <p class="product-variant-unavailable" data-variant-unavailable hidden>This combination is currently unavailable.</p>

        <button type="submit" class="btn btn-primary btn-add-to-cart" data-add-to-cart-btn {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
          <span data-add-to-cart-text>
            {% if product.selected_or_first_available_variant.available %}Add to cart{% else %}Sold out{% endif %}
          </span>
        </button>
      {% endform %}

      <script type="application/json" data-product-variants>{{ product.variants | json }}</script>

      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'text' %}
            <div class="product-block-text" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
          {% when 'collapsible' %}
            <details class="product-collapsible" {{ block.shopify_attributes }}>
              <summary>{{ block.settings.heading }}</summary>
              <div class="rte">{{ block.settings.content }}</div>
            </details>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product page",
  "settings": [
    {
      "type": "select",
      "id": "variant_display",
      "label": "Variant selector style",
      "options": [
        { "value": "buttons", "label": "Buttons / swatches" },
        { "value": "dropdown", "label": "Dropdown" }, 
        { "value": "cards", "label": "Pack / quantity cards" },
        { "value": "card_with_img", "label": "Pack / quantity cards Image" }
      ],
      "default": "buttons",
      "info": "\"Pack / quantity cards\" works best when each variant value is a distinct pack size (e.g. Single, 3-Pack, 5-Pack) with its own price set in Admin. Add matching 'Pack card details' blocks below to add subtitles and badges."
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [ { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Free shipping over $50</p>" } ]
    },
    {
      "type": "collapsible",
      "name": "Collapsible row",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shipping & Returns" },
        { "type": "richtext", "id": "content", "label": "Content" }
      ]
    },
    {
      "type": "pack_option",
      "name": "Pack card details",
      "settings": [
        { "type": "text", "id": "option_value", "label": "Matches variant option value", "info": "Must exactly match one of the product's option values, e.g. \"Family 3-Pack\"." },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "info": "e.g. \"3 rings \u00b7 save $50 a ring\"", "default": "Subtitle" },
        { "type": "number", "id": "units_in_pack", "label": "Units in this pack", "info": "Used to calculate the \"each\" price. Leave as 1 for a single item.", "default": 1 },
        { "type": "text", "id": "badge_text", "label": "Ribbon badge text (optional)", "info": "e.g. \"MOST POPULAR\" or \"\u2605 1 RING FREE\"", "default": "Badge Text" },
        {
          "type": "select",
          "id": "badge_style",
          "label": "Badge color",
          "options": [
            { "value": "popular", "label": "Red (Most popular)" },
            { "value": "highlight", "label": "Green (Bonus / free item)" }
          ],
          "default": "popular"
        }
      ]
    }
  ]
}
{% endschema %}
