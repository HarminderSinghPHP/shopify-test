<section class="search-page container">
  <h1 class="heading-font">Search results for "{{ search.terms }}"</h1>
  <div class="product-grid" style="--cols:4;">
    {% for item in search.results %}
      {% if item.object_type == 'product' %}
        {% unless item.tags contains 'hide-from-store' %}
          {% render 'product-card', product: item %}
        {% endunless %}
      {% else %}
        <a href="{{ item.url }}" class="search-result-other">{{ item.title }}</a>
      {% endif %}
    {% else %}
      <p>No results found.</p>
    {% endfor %}
  </div>
</section>
{% schema %}
{ "name": "Search page", "settings": [] }
{% endschema %}
