{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'section-main-blog.css' | asset_url | stylesheet_tag }}
{{ 'custom-blog.css' | asset_url | stylesheet_tag }}

<style>
  .capitalize-text {
    text-transform: capitalize;
    font-weight: bold;
    font-size: 36px !important;
    line-height: 40px !important;
}
  @media (max-width: 767px) {
    .capitalize-text {
      font-size: 20px !important;
      text-align:center;
    }
    .title--primary {
      margin-top: 10px;
      margin-bottom: 5px;
    }
    .temp_official-blog .tradmark-blog{
      top: 0px;
    }
  }
</style>


<div class="blog-main-banner-a index_banner " style="cursor:pointer;" bis_skin_checked="1">
  <img class="blog-main-banner-a-hero" src={{ section.settings.banner_image | image_url }}
</div>

{%- paginate blog.articles -%}
  <div class="main-blog page-width section-{{ section.id }}-pa" style="padding: 0 1rem;">
    <!-- Blog Title --> 
    <h1 class="title--primary{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %} capitalize-text">

      {% assign url_parts = request.path | split: '/' %}
      {% assign last_part = url_parts | last %}
      {% assign last_part_no_hyphens = last_part | replace: '-', ' ' %}
      {% assign words = last_part_no_hyphens | split: ' ' %}
      {% assign capitalized_words = '' %}
      
      {% for word in words %}
        {% assign capitalized_words = capitalized_words | append: word | capitalize | append: ' ' %}
      {% endfor %}
      
      {% if last_part == "official-blog"  %} {{ capitalized_words | strip }} | Medical Saunas<span class="tradmark-blog">™</span>  {% else %}  Official Blog | {{ capitalized_words | strip }}  {% endif %}   
      
      {% comment %}  {{ blog.title | escape }}   {% endcomment %}
    </h1>  
 {% comment %} <ul>
      <li>
        {%- for tag in blog.all_tags -%}
          <a href="{{ blog.url }}/tagged/{{ tag | handle }}">{{ tag }}</a>{% unless forloop.last %}, {% endunless %}
        {%- endfor -%}
      </li>
    </ul>
    {% endcomment %}
    <!-- Create a file named blog-content.liquid in the 'sections' folder -->
    {% paginate blog.articles by 10 %}
      <div class="blog-page">
        <div class="blog-posts">
          <div class="grid">

           {% for article in blog.articles  %}
              
              <div class="grid-item">
                {%- render 'custom-article',
                  article: article,
                  media_height: section.settings.image_height,
                  media_aspect_ratio: article.image.aspect_ratio,
                  show_image: section.settings.show_image,
                  show_date: section.settings.show_date,
                  show_author: section.settings.show_author,
                  show_excerpt: true
                -%}
              </div>
              
            {% endfor %} 
            
          </div>
          
         
        </div>

        <div class="blog-sidebar">
          <div class="sidebar__wrapper">

            {% comment %}
             <div class="search-bar">
              <h3 class="sidebar__title">Search</h3>
              <form action="/search" method="get" role="search">
                <input type="search" name="q" placeholder="Enter to Search" aria-label="Search">
                <button type="submit">Go</button>
              </form>
            </div> 
             {% endcomment %}
            
            <div class="blog-categories">
              <h3 class="sidebar__title">Categories</h3>

              <ul>
                <li><a href="/blogs/official-blog/tagged/saunas">Saunas</a></li>
                <li><a href="/blogs/official-blog/tagged/outdoor-saunas">Outdoor Saunas</a></li>
                <li><a href="/blogs/official-blog/tagged/cold-plunge">Cold Plunge</a></li>
                <li><a href="/blogs/official-blog/tagged/traditional-saunas">Traditional Saunas</a></li>
              </ul>
            </div>
            <div class="recent-posts">
              <h3 class="sidebar__title">More Articles Like This</h3>
              <ul>
                {% assign blog_handles = "official-blog" | split: "," %}
           {% for handle in blog_handles %}
             {% for article in blogs[handle].articles limit: 8%}     
                  <li>
                    <a href="{{ article.url }}">{{ article.title }}</a>
                  </li>          
             {% endfor %}
         {% endfor %}
              </ul>
            </div>
          </div>
        </div>
      </div>
      <div class="pagination">
        {%- render 'pagination', paginate: paginate -%}
      </div>
    {% endpaginate %}
  </div>
{%- endpaginate -%}

{% schema %}
{
  "name": "t:sections.main-blog.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main-blog.settings.header.content"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "t:sections.main-blog.settings.show_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": true,
      "label": "t:sections.main-blog.settings.show_author.label"
    },
    {
      "type": "paragraph",
      "content": "t:sections.main-blog.settings.paragraph.content"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
  ]
}
{% endschema %}
