<section class="article-page container">
  <h1 class="heading-font">{{ article.title }}</h1>
  <p class="article-meta">{{ article.published_at | date: '%B %d, %Y' }} &middot; {{ article.author }}</p>
  {% if article.image %}<img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.title | escape }}" class="article-image">{% endif %}
  <div class="rte">{{ article.content }}</div>
</section>
{% schema %}
{ "name": "Article", "settings": [] }
{% endschema %}
