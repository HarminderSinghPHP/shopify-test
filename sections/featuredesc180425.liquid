<section class="features-icons">
  <div class="features-container">
    {% for block in section.blocks %}
      <div class="feature-item">
        <img src="{{ block.settings.icon | image_url }}" alt="Icon" class="feature-icon" />
        <h3 class="feature-title">{{ block.settings.title }}</h3>
      </div>
    {% endfor %}
  </div>
</section>

<style>
  .features-icons {
    padding: 40px 20px;
    background-color: #f9f9f9; 
  }
  .features-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 80px;
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .feature-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .feature-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 10px;
  }
  .feature-title {
    font-size: 16px;
    font-weight: 600;
    color: #000;
    margin: 0;
  }

  @media (max-width: 600px) {
    .feature-title {
      font-size: 14px;
    }
    .feature-icon {
      width: 32px;
      height: 32px;
    }
      .features-container {
      gap: 10px;
    }
  }
</style>

{% schema %}
{
  "name": "Features Icons",
  "settings": [],
  "blocks": [
    {
      "type": "icon",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "featuredesc180425",
