<!-- section-name.liquid -->
<section>
  <div class="image-position">
      <img class="desktop_collectionimg" src="{{ section.settings.desktop-image | img_url:'master' }}" />
      <img class="mobile_collectionimg" src="{{ section.settings.mobile-image | img_url:'master' }}"   />
    <div class="collectionbanner-inner">
        <h1 class="collectionbanner-head">{{ section.settings.heading }} </h1>
         <p class="collectionbanner-desc">{{ section.settings.paragraph_text }} <span></span></p>
        <a href="#" class="collectionbanner-link">{{ section.settings.button_text }}</a>   
    </div>
    </div>
</section>

<style>
  .desktop_collectionimg{
    width:100%;
    display:flex;
  }
    img.mobile_collectionimg {
      display:none;
  }
  .image-position {
      position: relative;
  }
  .collectionbanner-inner {
      position: absolute;
      top: 40%;
      left: 10%;
  }
  h1.collectionbanner-head {
      color: #fff;
      font-size: 60px;
      font-weight: 600;
      margin: 0;
  }
  p.collectionbanner-desc {
      color: #fff;
      font-size: 18px;
      margin: 20px 0;
  }
  p.collectionbanner-desc span{
      display:block;
  }
  a.collectionbanner-link {
      color: #fff;
      border-bottom: 1px solid #fff;
      padding: 2px 0;
      font-size: 22px;
  }
  @media only screen and (max-width: 768px) {
    .desktop_collectionimg{
        display:none;
      }
    img.mobile_collectionimg {
        width: 100%;
        display:block;
    }
    .collectionbanner-inner {
        position: absolute;
        top: 35%;
        left: 5%;
    }
    h1.collectionbanner-head {
        font-size: 40px;
        font-weight: 500;
        margin: 0;
    }
    p.collectionbanner-desc {
        font-size: 14px;
        margin: 10px 0;
    }
    a.collectionbanner-link {
        padding: 2px 0;
        font-size: 22px;
    }
  }
</style>
{% schema %}
{
  "name": "collectionbanner-010425",
  "settings": [

     {
          "type": "image_picker",
          "id": "mobile-image",
          "label": "mobile-image"
        },
    {
          "type": "image_picker",
          "id": "desktop-image",
          "label": "desktop-image"
        },
    
    {
      "type": "text",
      "id": "heading",
      "label": "desktop-headingtext",
      "default": "Welcome to Our Store"
    },
    {
      "type": "textarea",
      "id": "paragraph_text",
      "label": "desktop-paratext",
      "default": "This is a sample paragraph."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button-text",
      "default": "Click Me"
    }
  ],
 
  "presets": [
    {
      "name": "collectionbanner-010425",
      "category": "Custom"
    }
  ]
}
{% endschema %}