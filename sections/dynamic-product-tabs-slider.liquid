{% liquid
  assign section_key = 'product-tabs-slider-' | append: section.id
%}

<section
  id="{{ section_key }}"
  class="product-tabs-slider-section"
  style="
    --pts-section-bg: {{ section.settings.section_background }};
    --pts-container-width: {{ section.settings.container_width }}px;

    --pts-padding-top: {{ section.settings.padding_top }}px;
    --pts-padding-bottom: {{ section.settings.padding_bottom }}px;
    --pts-padding-left: {{ section.settings.padding_left }}px;
    --pts-padding-right: {{ section.settings.padding_right }}px;

    --pts-tabs-gap: {{ section.settings.tabs_gap }}px;
    --pts-tabs-bottom-space: {{ section.settings.tabs_bottom_space }}px;

    --pts-tab-bg: {{ section.settings.tab_background }};
    --pts-tab-color: {{ section.settings.tab_text_color }};
    --pts-tab-active-bg: {{ section.settings.tab_active_background }};
    --pts-tab-active-color: {{ section.settings.tab_active_text_color }};
    --pts-tab-border-color: {{ section.settings.tab_border_color }};
    --pts-tab-radius: {{ section.settings.tab_border_radius }}px;
    --pts-tab-font-size: {{ section.settings.tab_font_size }}px;
    --pts-tab-font-weight: {{ section.settings.tab_font_weight }};
    --pts-tab-padding-y: {{ section.settings.tab_padding_vertical }}px;
    --pts-tab-padding-x: {{ section.settings.tab_padding_horizontal }}px;

    --pts-card-gap: {{ section.settings.product_gap }}px;
    --pts-desktop-columns: {{ section.settings.desktop_columns }};
    --pts-tablet-columns: {{ section.settings.tablet_columns }};
    --pts-mobile-columns: {{ section.settings.mobile_columns }};

    --pts-image-bg: {{ section.settings.image_background }};
    --pts-image-radius: {{ section.settings.image_border_radius }}px;
    --pts-card-bg: {{ section.settings.card_background }};

    --pts-vendor-color: {{ section.settings.vendor_color }};
    --pts-vendor-size: {{ section.settings.vendor_size }}px;
    --pts-title-color: {{ section.settings.title_color }};
    --pts-title-size: {{ section.settings.title_size }}px;
    --pts-price-color: {{ section.settings.price_color }};
    --pts-sale-price-color: {{ section.settings.sale_price_color }};
    --pts-price-size: {{ section.settings.price_size }}px;

    --pts-sale-bg: {{ section.settings.sale_badge_background }};
    --pts-sale-color: {{ section.settings.sale_badge_text_color }};

    --pts-button-bg: {{ section.settings.button_background }};
    --pts-button-color: {{ section.settings.button_text_color }};
    --pts-button-hover-bg: {{ section.settings.button_hover_background }};
    --pts-button-hover-color: {{ section.settings.button_hover_text_color }};
  "
>
  <div class="product-tabs-slider-container">

    {% if section.settings.heading != blank %}
      <div class="product-tabs-slider-heading-wrap product-tabs-slider-heading-wrap--{{ section.settings.heading_alignment }}">
        <{{ section.settings.heading_tag }} class="product-tabs-slider-heading">
          {{ section.settings.heading }}
        </{{ section.settings.heading_tag }}>

        {% if section.settings.subheading != blank %}
          <div class="product-tabs-slider-subheading rte">
            {{ section.settings.subheading }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="product-tabs-slider-tabs" role="tablist">

        {% if section.settings.show_shop_all %}
          <button
            type="button"
            class="product-tabs-slider-tab is-active"
            data-tab-target="shop-all-{{ section.id }}"
            role="tab"
            aria-selected="true"
          >
            {{ section.settings.shop_all_text }}
          </button>
        {% endif %}

        {% for block in section.blocks %}
          {% if block.settings.collection != blank %}
            <button
              type="button"
              class="product-tabs-slider-tab {% unless section.settings.show_shop_all %}{% if forloop.first %}is-active{% endif %}{% endunless %}"
              data-tab-target="collection-{{ block.id }}"
              role="tab"
              aria-selected="{% if section.settings.show_shop_all %}false{% elsif forloop.first %}true{% else %}false{% endif %}"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.custom_tab_title != blank %}
                {{ block.settings.custom_tab_title }}
              {% else %}
                {{ block.settings.collection.title }}
              {% endif %}
            </button>
          {% endif %}
        {% endfor %}
      </div>

      <div class="product-tabs-slider-content">

        {% if section.settings.show_shop_all %}
          {% liquid
            assign shop_all_dedup = ''
            assign shop_all_count = 0
            for block in section.blocks
              if block.settings.collection != blank
                for product in block.settings.collection.products
                  unless shop_all_dedup contains product.id
                    if shop_all_count < section.settings.products_limit
                      assign shop_all_dedup = shop_all_dedup | append: ',' | append: product.id
                      assign shop_all_count = shop_all_count | plus: 1
                    endif
                  endunless
                endfor
              endif
            endfor
          %}
          <div
            id="shop-all-{{ section.id }}"
            class="product-tabs-slider-panel is-active"
            role="tabpanel"
          >
            {% if shop_all_count > 0 %}
              <div class="product-tabs-slider-track-wrap">
                <button
                  type="button"
                  class="product-tabs-slider-arrow product-tabs-slider-arrow--prev"
                  aria-label="Previous products"
                >
                  &#8592;
                </button>

                <div class="product-tabs-slider-track">
                  {% assign displayed_products = blank %}
                  {% assign product_counter = 0 %}

                  {% for block in section.blocks %}
                    {% if block.settings.collection != blank %}
                      {% for product in block.settings.collection.products %}
                        {% unless displayed_products contains product.id %}
                          {% if product_counter < section.settings.products_limit %}
                            {% render 'product-card', product: product %}
                            {% capture displayed_products %}
                              {{ displayed_products }},{{ product.id }}
                            {% endcapture %}
                            {% assign product_counter = product_counter | plus: 1 %}
                          {% endif %}
                        {% endunless %}
                      {% endfor %}
                    {% endif %}
                  {% endfor %}
                </div>

                <button
                  type="button"
                  class="product-tabs-slider-arrow product-tabs-slider-arrow--next"
                  aria-label="Next products"
                >
                  &#8594;
                </button>
              </div>
            {% else %}
              <p class="product-tabs-slider-empty">No products to show yet.</p>
            {% endif %}
          </div>
        {% endif %}

        {% for block in section.blocks %}
          {% if block.settings.collection != blank %}
            <div
              id="collection-{{ block.id }}"
              class="product-tabs-slider-panel {% unless section.settings.show_shop_all %}{% if forloop.first %}is-active{% endif %}{% endunless %}"
              role="tabpanel"
            >
              {% if block.settings.collection.products.size > 0 %}
                <div class="product-tabs-slider-track-wrap">
                  <button
                    type="button"
                    class="product-tabs-slider-arrow product-tabs-slider-arrow--prev"
                    aria-label="Previous products"
                  >
                    &#8592;
                  </button>

                  <div class="product-tabs-slider-track">
                    {% for product in block.settings.collection.products limit: section.settings.products_limit %}
                      {% render 'product-card', product: product %}
                    {% endfor %}
                  </div>

                  <button
                    type="button"
                    class="product-tabs-slider-arrow product-tabs-slider-arrow--next"
                    aria-label="Next products"
                  >
                    &#8594;
                  </button>
                </div>
              {% else %}
                <p class="product-tabs-slider-empty">No products in this collection yet.</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>


{% style %}
  #{{ section_key }} {
    width: 100%;
    background: var(--pts-section-bg);
    padding:
      var(--pts-padding-top)
      var(--pts-padding-right)
      var(--pts-padding-bottom)
      var(--pts-padding-left);
    box-sizing: border-box;
  }

  #{{ section_key }} *,
  #{{ section_key }} *::before,
  #{{ section_key }} *::after {
    box-sizing: border-box;
  }

  #{{ section_key }} .product-tabs-slider-container {
    width: 100%;
    max-width: var(--pts-container-width);
    margin: 0 auto;
  }

  #{{ section_key }} .product-tabs-slider-heading-wrap--left {
    text-align: left;
  }

  #{{ section_key }} .product-tabs-slider-heading-wrap--center {
    text-align: center;
  }

  #{{ section_key }} .product-tabs-slider-heading-wrap--right {
    text-align: right;
  }

  #{{ section_key }} .product-tabs-slider-heading {
    margin: 0 0 10px;
    color: {{ section.settings.heading_color }};
    font-family:
      {{ section.settings.heading_font.family }},
      {{ section.settings.heading_font.fallback_families }};
    font-style: {{ section.settings.heading_font.style }};
    font-weight: {{ section.settings.heading_weight }};
    font-size: {{ section.settings.heading_size }}px;
    line-height: {{ section.settings.heading_line_height }};
  }

  #{{ section_key }} .product-tabs-slider-subheading {
    margin-bottom: 25px;
    color: {{ section.settings.subheading_color }};
    font-family:
      {{ section.settings.subheading_font.family }},
      {{ section.settings.subheading_font.fallback_families }};
    font-size: {{ section.settings.subheading_size }}px;
  }

  #{{ section_key }} .product-tabs-slider-subheading p {
    margin: 0;
  }

  #{{ section_key }} .product-tabs-slider-tabs {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--pts-tabs-gap);
    margin-bottom: var(--pts-tabs-bottom-space);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  #{{ section_key }} .product-tabs-slider-tabs::-webkit-scrollbar {
    display: none;
  }

  #{{ section_key }} .product-tabs-slider-tab {
    flex: 0 0 auto;
    padding:
      var(--pts-tab-padding-y)
      var(--pts-tab-padding-x);
    border: 1px solid var(--pts-tab-border-color);
    border-radius: var(--pts-tab-radius);
    background: var(--pts-tab-bg);
    color: var(--pts-tab-color);
    font-family:
      {{ section.settings.tab_font.family }},
      {{ section.settings.tab_font.fallback_families }};
    font-size: var(--pts-tab-font-size);
    font-weight: var(--pts-tab-font-weight);
    line-height: 1;
    cursor: pointer;
    transition: 0.25s ease;
    white-space: nowrap;
  }

  #{{ section_key }} .product-tabs-slider-tab:hover,
  #{{ section_key }} .product-tabs-slider-tab.is-active {
    background: var(--pts-tab-active-bg);
    color: var(--pts-tab-active-color);
    border-color: var(--pts-tab-active-bg);
  }

  #{{ section_key }} .product-tabs-slider-panel {
    display: none;
  }

  #{{ section_key }} .product-tabs-slider-empty {
    margin: 0;
    padding: 40px 20px;
    text-align: center;
    color: #666666;
    font-size: 15px;
  }

  #{{ section_key }} .product-tabs-slider-panel.is-active {
    display: block;
  }

  #{{ section_key }} .product-tabs-slider-track-wrap {
    position: relative;
  }

  #{{ section_key }} .product-tabs-slider-track {
    display: flex;
    gap: var(--pts-card-gap);
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  #{{ section_key }} .product-tabs-slider-track::-webkit-scrollbar {
    display: none;
  }

  #{{ section_key }} .product-card {
    position: relative;
    flex:
      0 0
      calc(
        (100% - ((var(--pts-desktop-columns) - 1) * var(--pts-card-gap)))
        / var(--pts-desktop-columns)
      );
    min-width: 0;
    scroll-snap-align: start;
  }

  #{{ section_key }} .product-tabs-slider-arrow {
    position: absolute;
    top: 42%;
    z-index: 10;
    width: 46px;
    height: 46px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid {{ section.settings.arrow_border_color }};
    border-radius: 50%;
    background: {{ section.settings.arrow_background }};
    color: {{ section.settings.arrow_color }};
    font-size: 22px;
    cursor: pointer;
    transform: translateY(-50%);
  }

  #{{ section_key }} .product-tabs-slider-arrow--prev {
    left: 0;
    transform: translate(-50%, -50%);
  }

  #{{ section_key }} .product-tabs-slider-arrow--next {
    right: 0;
    transform: translate(50%, -50%);
  }

  @media screen and (max-width: 989px) {
    #{{ section_key }} .product-card {
      flex-basis:
        calc(
          (100% - ((var(--pts-tablet-columns) - 1) * var(--pts-card-gap)))
          / var(--pts-tablet-columns)
        );
    }
  }

  @media screen and (max-width: 749px) {
    #{{ section_key }} {
      padding:
        {{ section.settings.mobile_padding_top }}px
        {{ section.settings.mobile_padding_right }}px
        {{ section.settings.mobile_padding_bottom }}px
        {{ section.settings.mobile_padding_left }}px;
    }

    #{{ section_key }} .product-tabs-slider-heading {
      font-size: {{ section.settings.heading_mobile_size }}px;
    }

    #{{ section_key }} .product-tabs-slider-tabs {
      justify-content: flex-start;
      margin-inline: -{{ section.settings.mobile_padding_left }}px;
      padding-inline: {{ section.settings.mobile_padding_left }}px;
    }

    #{{ section_key }} .product-card {
      flex-basis:
        calc(
          (100% - ((var(--pts-mobile-columns) - 1) * var(--pts-card-gap)))
          / var(--pts-mobile-columns)
        );
    }

    #{{ section_key }} .product-tabs-slider-arrow {
      display: none;
    }
  }
{% endstyle %}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const section = document.getElementById('{{ section_key }}');

    if (!section) return;

    const tabs = section.querySelectorAll('.product-tabs-slider-tab');
    const panels = section.querySelectorAll('.product-tabs-slider-panel');

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        const targetId = tab.getAttribute('data-tab-target');

        tabs.forEach(function (item) {
          item.classList.remove('is-active');
          item.setAttribute('aria-selected', 'false');
        });

        panels.forEach(function (panel) {
          panel.classList.remove('is-active');
        });

        tab.classList.add('is-active');
        tab.setAttribute('aria-selected', 'true');

        const targetPanel = section.querySelector('#' + targetId);

        if (targetPanel) {
          targetPanel.classList.add('is-active');

          const track = targetPanel.querySelector('.product-tabs-slider-track');

          if (track) {
            track.scrollLeft = 0;
          }
        }
      });
    });

    section.querySelectorAll('.product-tabs-slider-panel').forEach(function (panel) {
      const track = panel.querySelector('.product-tabs-slider-track');
      const previousButton = panel.querySelector('.product-tabs-slider-arrow--prev');
      const nextButton = panel.querySelector('.product-tabs-slider-arrow--next');

      if (!track || !previousButton || !nextButton) return;

      previousButton.addEventListener('click', function () {
        const card = track.querySelector('.product-card');
        const gap = parseFloat(getComputedStyle(track).gap) || 0;
        const amount = card ? card.offsetWidth + gap : track.clientWidth;

        track.scrollBy({
          left: -amount,
          behavior: 'smooth'
        });
      });

      nextButton.addEventListener('click', function () {
        const card = track.querySelector('.product-card');
        const gap = parseFloat(getComputedStyle(track).gap) || 0;
        const amount = card ? card.offsetWidth + gap : track.clientWidth;

        track.scrollBy({
          left: amount,
          behavior: 'smooth'
        });
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product Tabs Slider",
  "tag": "section",
  "class": "section-product-tabs-slider",
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "default": "h2",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "div", "label": "DIV" }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "assistant_n7"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "heading_mobile_size",
      "label": "Heading mobile size",
      "min": 14,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "default": "700",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra bold" }
      ]
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "label": "Heading line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "font_picker",
      "id": "subheading_font",
      "label": "Subheading font",
      "default": "assistant_n4"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    },

    {
      "type": "header",
      "content": "Collections and products"
    },
    {
      "type": "checkbox",
      "id": "show_shop_all",
      "label": "Show Shop All tab",
      "default": true
    },
    {
      "type": "text",
      "id": "shop_all_text",
