{% schema %}
{
  "name": "backgroundimg-010525",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "More Doctor-Based Saunas"
    },
    {
      "type": "header",
      "content": "Left Sauna Block"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left Sauna Image"
    },
    {
      "type": "text",
      "id": "left_title",
      "label": "Left Sauna Title",
      "default": "Medical Sauna™"
    },
    {
      "type": "text",
      "id": "left_subtitle",
      "label": "Left Sauna Subtitle",
      "default": "DOCTOR-DESIGNED INFRARED SAUNA"
    },
    {
      "type": "text",
      "id": "left_button_text",
      "label": "Left Button Text",
      "default": "SHOP MEDICAL SAUNA™"
    },
    {
      "type": "url",
      "id": "left_button_link",
      "label": "Left Button Link"
    },
    {
      "type": "header",
      "content": "Right Sauna Block"
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right Sauna Image"
    },
    {
      "type": "text",
      "id": "right_title",
      "label": "Right Sauna Title",
      "default": "Traditional Sauna™"
    },
    {
      "type": "text",
      "id": "right_subtitle",
      "label": "Right Sauna Subtitle",
      "default": "HANDCRAFTED SAUNA THAT PROVIDES NATURAL HEAT"
    },
    {
      "type": "text",
      "id": "right_button_text",
      "label": "Right Button Text",
      "default": "SHOP TRADITIONAL SAUNA™"
    },
    {
      "type": "url",
      "id": "right_button_link",
      "label": "Right Button Link"
    }
  ],
  "presets": [
    {
      "name": "backgroundimg-010525",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<div class="backgroung-image-section">
  <h2 class="backgroung-title">{{ section.settings.section_title }}</h2>
  <div class="backgroung-grid">
    <div class="backgroung-block" style="background-image: url('{{ section.settings.left_image | img_url: 'master' }}');">
      <div class="backgroung-overlay">
        <h3>{{ section.settings.left_title }}</h3>
        <p>{{ section.settings.left_subtitle }}</p>
        <a href="{{ section.settings.left_button_link }}" class="btn">{{ section.settings.left_button_text }}</a>
      </div>
    </div>
    <div class="backgroung-block" style="background-image: url('{{ section.settings.right_image | img_url: 'master' }}');">
      <div class="backgroung-overlay">
        <h3>{{ section.settings.right_title }}</h3>
        <p>{{ section.settings.right_subtitle }}</p>
        <a href="{{ section.settings.right_button_link }}" class="btn">{{ section.settings.right_button_text }}</a>
      </div>
    </div>
  </div>
</div>

<style>
.backgroung-image-section {
  text-align: center;
  padding: 40px 20px;
}
.backgroung-title {
    font-size: 36px;
    margin-bottom: 30px;
    font-weight: bold;
}
.backgroung-grid {
  display: flex;
  flex-wrap: nowrap;
  gap: 20px;
  justify-content: center;
}
.backgroung-block {
  position: relative;
  background-size: cover;
  background-position: center;
  border-radius: 12px;
  overflow: hidden;
  width: 45%;
  /* max-width: 420px; */
  height: 380px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.backgroung-block .backgroung-overlay {
  background-image: linear-gradient(to bottom, #00000000, #00000000, #0a0505);
  /* background: rgba(0, 0, 0, 0.6); */
  color: white;
  padding: 20px;
  text-align: left;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: end;
}
.backgroung-block h3 {
    font-size: 26px;
    margin: 0 0 8px;
    font-weight: 500;
}
.backgroung-block p {
  font-size: 13px;
  margin-bottom: 16px;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: #fff;
}
.backgroung-block .btn {
  background-color: #0096d9;
  color: white;
  text-decoration: none;
  padding: 10px 18px;
  border-radius: 4px;
  font-weight: bold;
  font-size: 14px;
  width: fit-content;
}
@media only screen and (max-width: 767px) {
  .backgroung-image-section {
    text-align: center;
    padding: 0px 20px;
}
  .backgroung-block {
    width: 100%;
    height: 380px;;
    align-items: center;
    justify-content: center;
}
.backgroung-title {
    font-size: 28px;
    margin-bottom: 18px;
    font-weight: bold;
    text-align: start;
} 
  .fqa-click:after {
    right: 5px;
}
  
}@media only screen and (max-width: 767px) {
  .backgroung-block p {
    text-align: start;
}
}
  
  
@media (max-width: 768px) {
  .backgroung-grid {
    flex-direction: column;
    align-items: center;
  }
}
</style>
