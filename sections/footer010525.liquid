                                </div>
                            </div>
                        </div>

                    </div>
                </div>

              <!-- post-q -->
                <div class="col-md-5  grid-order2">
                    <div class="image-div"> 
                        <img class="desktopimage" src="{{ section.settings.main-image | img_url:'master' }}" >
                        <!-- <img src="https://d2j861izbfuruy.cloudfront.net/medicalsaunas/shopify/product-qq2.png"> -->
                    </div>
<!-- postq1 -->
                    <div class="newsletter ">
                        <h4 class="q-stay">Stay Informed.<br>Feel Better.</h4>
                        <p class="be-q">Be the first to know about new products, 
                            exciting upgrades and promotions.</p>
                        {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
                        <input
                         id="NewsletterForm--{{ section.id }}"
                    type="email"
                    name="contact[email]"
                    class="fromjj form-control"
                    value="{{ form.email }}"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    {% if form.errors %}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="ContactFooter-error"
                    {% elsif form.posted_successfully? %}
                      aria-describedby="ContactFooter-success"
                    {% endif %}
                    placeholder="Email Address"
                    required >
                        <button class="btn submit-q" type="submit" name="commit"
                    id="Subscribe"
                    aria-label="{{ 'newsletter.button_label' | t }}" >SUBMIT</button>
                         {%- endform -%}
                        <p class="submit-p-q">We respect your data and privacy. Unsubscribe anytime.</p>
                      </div>
                </div>
            </div>
        </div>
    </footer>
