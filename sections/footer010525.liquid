{% schema %}
{
  "name": "footer010525",
  "settings": [
    {
      "type": "text",
      "id": "addclass",
      "label": "Addclass"
    },
    {
      "type": "image_picker",
      "id": "logo-image",
      "label": "Logo Image"
    },
    {
      "type": "image_picker",
      "id": "main-image",
      "label": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "mobileimage",
      "label": "Mobile Image"
    }
  ],
  "blocks": [
    {
      "type": "social_link",
      "name": "Social Icon",
      "settings": [
        {
          "type": "url",
          "id": "link",
          "label": "Social Link URL"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Social Icon Image"
        }
      ]
    },
    {
      "type": "link_group_heading",
      "name": "Heading_Name",
      "settings": [
        {
          "type": "text",
          "id": "group_id",
          "label": "Group ID (use to associate links)",
          "default": "group1"
        },
        {
          "type": "text",
          "id": "heading_text",
          "label": "Heading Text",
          "default": "Shop"
        }
      ]
    },
    {
      "type": "page_name_of_products",
      "name": "list_pages",
      "settings": [
        {
          "type": "text",
          "id": "group_id",
          "label": "Group ID (must match heading's Group ID)",
          "default": "group1"
        },
        {
          "type": "text",
          "id": "page_link",
          "label": "page_NAME",
          "default": "Example Link"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Page_URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "footer010525",
      "category": "Custom",
      "blocks": [
        {
          "type": "link_group_heading",
          "settings": {
            "group_id": "shop",
            "heading_text": "Shop"
          }
        },
        {
          "type": "page_name_of_products",
          "settings": {
            "group_id": "shop",
            "page_link": "Home",
            "link_url": "/"
          }
        },
        {
          "type": "page_name_of_products",
          "settings": {
            "group_id": "shop",
            "page_link": "Products",
            "link_url": "/collections/all"
          }
        }
      ]
    }
  ]
}
{% endschema %}

    <footer>
        <div class="container-fluid footer-q-section">
            <div class="row  row-display">
                <div class="col-md-7 grid-order">
                    <div class="row">
                        <div class="col-md-12">
                            <div class="footer-logo-q">
                                <p>
                                    <img class="desktopimage" src="{{ section.settings.logo-image | img_url:'master' }}" class="q365">
                                    <!-- <img src="https://medicalsaunas.com/cdn/shop/files/new-logo2.png?v=1733749565&width=365" class="q365"> -->
                                </p>
<ul class="footer-q1">
  {% for block in section.blocks %}
    {% if block.type == 'social_link' %}
      <li>
        <a href="{{ block.settings.link }}" target="_blank" rel="noopener">
          {% if block.settings.icon %}
            <img src="{{ block.settings.icon | img_url: 'master' }}" alt="Social Icon">
          {% endif %}
        </a>
      </li>
    {% endif %}
  {% endfor %}
</ul>

</div>
<div class="row">
{%- assign group1_id = "group1" -%}
{%- assign group2_id = "group2" -%}

<!-- First Column -->
<div class="col-md-4 shop-space3">
  {% for heading in section.blocks %}
    {% if heading.type == "link_group_heading" and heading.settings.group_id == group1_id %}
      <ul class="list-none-q">
        <h5 class="shop-q">{{ heading.settings.heading_text }}</h5>
        {% for link in section.blocks %}
          {% if link.type == "page_name_of_products" and link.settings.group_id == group1_id %}
            <li>
              <a href="{{ link.settings.link_url }}" class="anchor-q">
                {{ link.settings.page_link }}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}
  {% endfor %}
</div>

<!-- Second Column -->
<div class="col-md-4 shop-space3">
  {% for heading in section.blocks %}
    {% if heading.type == "link_group_heading" and heading.settings.group_id == group2_id %}
      <ul class="list-none-q">
        <h5 class="shop-q">{{ heading.settings.heading_text }}</h5>
        {% for link in section.blocks %}
          {% if link.type == "page_name_of_products" and link.settings.group_id == group2_id %}
            <li>
              <a href="{{ link.settings.link_url }}" class="anchor-q">
                {{ link.settings.page_link }}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}
  {% endfor %}
</div>                              

                                <div class="col-md-4 shop-space"></div>
                            </div>

