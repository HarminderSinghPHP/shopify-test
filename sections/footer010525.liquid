                                            <li>
                                                <p class="q-p">Open everyday at 5AM - 11:30PM</p>
                                            </li>
                                        </ul>
                                        <ul class="list-none-q">
                                            <li>
                                                <li><a href="tel:(818) 962-0774" class="anchor-q">
                                                  <img src="https://cdn.shopify.com/s/files/1/0897/8953/0400/files/phone-svgrepo-com.svg?v=1734529789" class="call-width" alt=""> Support: (818) 962-07746</a></li>
