 <style>
    #{{ section.id }}  iframe {
      aspect-ratio: 16/9;
    }

    #{{ section.id }} .video-container {
      margin: 2rem;
      max-height: 300px;
    }

    #{{ section.id }} img {
      display: block;
      max-width: 100%;
    }

    #{{ section.id }} main {
      display: grid;
      place-items: center;
      min-height: 65vh;
    }

  

   #{{ section.id }} .image-container {
     max-width: 1400px;
    max-height: 100%;
    aspect-ratio: 0;
    }

    #{{ section.id }}  .slider-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: left;
    }

    #{{ section.id }}  .image-before {
      position: absolute;
      inset: 0;
      width: var(--position);
      
    }

   

    #{{ section.id }}  .slider:focus-visible ~ .slider-button {
      outline: 5px solid black;
      outline-offset: 3px;
    }

    #{{ section.id }}  .slider-line {
      position: absolute;
      inset: 0;
      width: .2rem;
      height: 100%;
      background-color: #fff;
      left: var(--position);
      transform: translateX(-50%);
      pointer-events: none;
    }

    #{{ section.id }} .slider-button {
      position: absolute;
      background-color: #fff;
      color: black;
      padding: .5rem;
      border-radius: 100vw;
      display: grid;
      place-items: center;
      top: 50%;
      left: var(--position);
      transform: translate(-50%, -50%);
      pointer-events: none;
    
    }
   #{{ section.id }} .slider-button {
    height: 100%;
    max-width: 0px!important;
    box-shadow: rgba(99, 99, 99, 0.2) 0px 2px 8px 0px;
    padding: 1px;
}
    #{{ section.id }} svg {
    background-color: white;
    width: 33px;
    padding: 4px;
    border-radius: 7px;
}
   @media only screen and (max-width: 600px) {
   #{{ section.id }} main {
      display: grid;
      place-items: center;
      min-height: 22vh;
    }
}
#{{section.id}} .feature-h-text{
  background-color: #205d8c;
   margin-bottom: 0.6%;
   display: flex;
    justify-content: space-between;
    z-index: 2 !important;
    position: relative;
}
 #{{section.id}}  .design-p {
    font-family: 'Open Sans', sans-serif !important;
    text-align: center;
    font-weight: bold;
    font-size: 14px;
    margin-top:10px;
}
   #{{section.id}} .images-compare-label {
    display: block !important;
}
  </style>

<section id="{{ section.id }}" class="{{ section.settings.addclass }}" style="padding-top:{{ section.settings.ptop }}px; padding-bottom:{{ section.settings.pbottom }}px">
 <div class="acc-bg-blue w3_bg">
   <div class="container w3_bg">
    <div class="feature-h-text collapsed  " data-toggle="collapse" data-target="#traditional4-acc14">
     
     <h4 class="head-a1">DESIGNER <span>SHOWCASES</span></h4>
     <i class="fa fa-angle-up head-arrow arrow-gray"></i>
     </div>
  </div>
 </div>
  <div id="traditional4-acc14" class="collapse in container ">
    {% for block in section.blocks %}
     <div >
      <style>
          #{{ section.id }} .container-{{forloop.index}} {
      display: grid;
      place-content: center;
      position: relative;
      overflow: hidden;
      /* border-radius: 1rem; */
      --position: 50%;
    }
   #{{ section.id }}  .slider-{{forloop.index}} {
      position: absolute;
      inset: 0;
      cursor: pointer;
      opacity: 0;
      width: 100%;
      height: 100%;
    }
      </style>
  <main>
    <div class="container-{{forloop.index}}">
      <div class="image-container">
        <div><span class="images-compare-label">Open</span><img  class="image-before slider-image" src="{{ block.settings.img01 | img_url:'master' }}" alt="color photo"  /></div>
        <div><span class="images-compare-label" style="left:auto; right:10px;">Close</span><img class="image-after slider-image" src="{{ block.settings.img02 | img_url:'master' }}" alt="black and white" /></div>
        
        
      </div>
      <input  type="range"  min="0"  max="100" value="50" aria-label="Percentage of before photo shown"  class="slider-{{forloop.index}}"/>
      <div class="slider-line" aria-hidden="true"></div>
      <div class="slider-button" aria-hidden="true">
        <div class="images-compare-handle" style=""><span class="images-compare-left-arrow"></span><span class="images-compare-right-arrow"></span></div>
        
      </div>
      
    </div>
   
  </main>
  <p class="design-p" style="color:{{ block.settings.hcolor }}; font-size:{{ block.settings.hsize }}px">{{ block.settings.h01 }}</p>
      <script>
    $(document).ready(function () {
      $('.slider-{{forloop.index}}').on('input', function () {
        const value = $(this).val() + '%';
        $('.container-{{forloop.index}}').css('--position', value);
      });
    });
  </script>
       </div>
    {% endfor %}
  </div>
 
</section>
  
    {% schema %}
  {
    "name": "Traditional4 showcase",
    "settings": [
      {
       "type": "text",
       "id": "addclass",
       "label": "addclass"
    },
      {
       "type": "text",
       "id": "addclass32",
       "label": "Add class"
    },
      
       
       {
      "type": "text",
      "id": "ptop",
      "label": "pading top"
      },
      {
      "type": "text",
      "id": "pbottom",
      "label": "Padding bottom"
      }
    ],
    "blocks": [
      {
        "type": "image-showcase",
        "name":"showcase",
        "settings": [
          {
          "type": "text",
          "id": "h01",
          "label": "heading"
        },
         {
          "type": "image_picker",
          "id": "img01",
          "label": "slider Image 1"
        },
          {
          "type": "image_picker",
          "id": "img02",
          "label": "slider Image 2"
        },
         {
        "type": "text",
        "id": "hsize",
        "label": "Heading Size"    
        },
         {
        "type": "color",
        "id": "hcolor",
        "label": "Heading color"    
        },
        ]
      }
    ],
     "presets": [
    {
      "name": "Traditional4 showcase"
       }
  ]
  }
{% endschema %}