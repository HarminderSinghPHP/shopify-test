<section id="{{ section.id }}" class="{{ section.settings.addclass }} fly">
  <div class="image-position">
  <style>
 .hy{
      background-color: #f9f9fb;
      font-family: Arial, sans-serif;
    }

.faq-container {
    width: 100%;
    max-width: none;
    margin: 20px auto;
    padding: 40px;
    background-color: white;
    /* border: 2px dashed #c1a1f7; */
    border-radius: 10px;
}

   .faq-title {
    font-size: 36px;
    font-weight: 600;
}

    .faq-item {
      background-color: #f7f7f8;
      border: none;
      border-radius: 8px;
      margin-bottom: 10px;
      padding: 15px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
    }

    .faq-item:hover {
      background-color: #ededf0;
    }

    .faq-icon {
      font-size: 1.2rem;
      color: #000;
    }
  </style>


  <div class="container faq-container hy">
    <div class="row">
      <div class="col-md-4">
        <h3 class="faq-title">Frequently Asked<br>Questions</h3>
      </div>
      <div class="col-md-8">
        <div class="faq-item">
          <span>How custom can my sauna really be?</span>
          <span class="faq-icon">➤</span>
        </div>
        <div class="faq-item">
          <span>What's the typical timeline for a custom build?</span>
          <span class="faq-icon">➤</span>
        </div>
        <div class="faq-item">
          <span>Do I need to have exact measurements before starting?</span>
          <span class="faq-icon">➤</span>
        </div>
        <div class="faq-item">
          <span>Can I choose between infrared, steam, or a hybrid system?</span>
          <span class="faq-icon">➤</span>
        </div>
        <div class="faq-item">
          <span>Is installation included with delivery?</span>
          <span class="faq-icon">➤</span>
        </div>
        <div class="faq-item">
          <span>What type of support will I have during the process?</span>
          <span class="faq-icon">➤</span>
        </div>
        <div class="faq-item">
          <span>Can I see design concepts before I commit?</span>
          <span class="faq-icon">➤</span>
        </div>
        <div class="faq-item">
          <span>Is there a warranty on custom saunas?</span>
          <span class="faq-icon">➤</span>
        </div>
      </div>
    </div>
  </div>


</div>
</section>

