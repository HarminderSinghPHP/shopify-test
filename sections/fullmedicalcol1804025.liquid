  {% schema %}
    {
        "name":"Custom Product Section",
        "tag":"section",
        "class":"custom-type1",
        "settings": [
                  {
                    "type":"textarea",
                    "id":"heading",
                    "label":"Heading",
                    "default": "<span>Designer Showcases</span> around the world"
                 },
                 {
                    "type": "checkbox",
                    "id": "default_open",
                    "label": "Open by Default",
                    "default": true
                },
                {
                  "type": "collection",
                  "id": "custom_collection",
                  "label": "Select Collection"
                },
                {
                  "type": "product",
                  "id": "custom_products1",
                  "label": "Select products"
                },
                {
                  "type": "product",
                  "id": "custom_products2",
                  "label": "Select products"
                },
                {
                  "type": "product",
                  "id": "custom_products3",
                  "label": "Select products"
                },
                {
                  "type": "product",
                  "id": "custom_products4",
                  "label": "Select products"
                },
                {
                  "type": "text",
                  "id": "class_name",
                  "label": "Add Class Name"
                }
        ],
        "presets":[
           {
              "name":"Custom Product Section"
           }
        ]
     }
{% endschema %}