{% schema %}
  {
    "name": "frozen1 accordion",
    "settings": [
      {
        "type": "textarea",
        "id": "heading",
        "label":"Heading"
      }
    ],
    "blocks":[
      {
        "type":"accordion",
        "name":"Accordion",
        "settings":[
          {
             "type": "text",
             "id": "title",
            "label":"Accordion Heading"
          },
          {
             "type": "textarea",
             "id": "content",
            "label":"Accordion Content"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "frozen1 accordion"
      }
    ]
  }
{% endschema %}