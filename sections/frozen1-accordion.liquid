<section class="gap-4">
        <div class="container">
            <div class="row">
                <div class="col-md-2"></div>
                <div class="col-md-8" style="text-align: center;">
                    
                    <h4 class="unc white uuu">{{ section.settings.heading }}</h4>
                    <div class="panel-group" id="accordion-1" style="margin-top: 2rem;">


        {% for block in section.blocks %} 
          {% if block.settings.title != blank %}
                    <div class="panel panel-default panel-border">
                            <div class="panel-heading panel-bg">
                                <h4 class="panel-title h4-panel collapsed" data-toggle="collapse" data-parent="#accordion-1" href="#{{ block.id }}" style="text-align: start;">

                                    <span class="white" style="margin : auto 20px;">{{ block.settings.title }}
                                    </span>

                                    <a>
                                        <span class="glyphicon "></span>
                                        <i class="fa fa-angle-down white pull-right arrow-size9"></i>
                                    </a>
                                </h4>
                            </div>
                            <div id="{{ block.id }}" class="panel-collapse collapse" style="height: 0px;">
                                <div class="panel-body left-text p-6">
                                    <p style="margin : auto 20px;">
                                    {{ block.settings.content }} </p>

                                </div>
                            </div>
                        </div>
            {% endif %}
            {% endfor %}




                      
