 <script>
document.addEventListener("DOMContentLoaded", function () {
    // Get URL parameters
    const urlParams = new URLSearchParams(window.location.search);
    const tCount = parseInt(urlParams.get('TCount')) || 0; // Convert to number
    const email = urlParams.get('email') || ""; 


  

    console.log("TCount:", tCount);
    console.log("Email:", email);

    // Ensure elements exist before setting values
    const starsInput = document.getElementById("stars");
    const emailInput = document.getElementById("email");
    
    if (starsInput) starsInput.value = tCount;
    if (emailInput) emailInput.value = email;

    // Get the button
    const submitBtn = document.getElementById("submitBtn");

    if (!submitBtn) {
        console.error("Submit button (submitBtn) not found!");
        return;
    }
   if (tCount > 3) {

      // Prepare API request data
            const requestData = {
                rating: tCount,
                name: 'Trust Pilot',  
                email: email, 
                phone: 'Trust Pilot', 
                message: 'Trust Pilot',
            };

          
            fetch("https://www.drrecommendations.com/api/orders/reviews.php", {
                method: "POST",
                headers: {
                    "X-Auth-Token": "shptdrrecsk_M33WklhE1KksgF4ZaTvGQ9eDvbZWBUjj",
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(requestData)
            })
            .then(response => response.json())
            .then(data => {
                  console.log("API Response:", data);
                  //alert("Review submitted successfully!"); // Show success message
                 
            })
            .catch(error => {
                console.error("Error:", error);
                alert("Failed to submit review.");
            });
     
             window.location.href = "https://www.trustpilot.com/evaluate/www.medicalsaunas.com";
             return; // Stop script execution
           

   }else{
    document.getElementById("from-submitdata").style.display = "block"
  }




    // Button click event
    submitBtn.addEventListener("click", function (event) {
        event.preventDefault(); // Prevent default form submission
        const nameInput = document.getElementById("name");
        const phoneInput = document.getElementById("phone");
        const messageInput = document.getElementById("message");

        const name = nameInput.value.trim();
        const phone = phoneInput.value.trim();
        const message = messageInput.value.trim();

        if (tCount <= 3) {


            // Prepare API request data
            const requestData = {
                rating: tCount,
                name: name,  
                email: email, 
                phone: phone, 
                message: message
            };

          
            fetch("https://www.drrecommendations.com/api/orders/reviews.php", {
                method: "POST",
                headers: {
                    "X-Auth-Token": "shptdrrecsk_M33WklhE1KksgF4ZaTvGQ9eDvbZWBUjj",
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(requestData)
            })
            .then(response => response.json())
            .then(data => {
                 console.log("API Response:", data);
                 //alert("Review submitted successfully!"); // Show success message
                 window.location.href = "https://medicalsaunas.com/pages/thank-feed";
            })
            .catch(error => {
                console.error("Error:", error);
                alert("Failed to submit review.");
            });
          
            document.querySelector("form").submit(); // Submit form normally
        }
      
    });


  
});
    
</script>

