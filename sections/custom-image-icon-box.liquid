<div class="sauna-banner" style="background-image: url({{ section.settings.bg_image | image_url }});">
  <div class="sauna-overlay">
    <h2 class="sauna-heading">{{ section.settings.heading }}</h2>
    <div class="sauna-features">
      {% for block in section.blocks %}
        <div class="feature-item">
          {% if block.settings.icon_image %}
            <img class="icon-image" src="{{ block.settings.icon_image | image_url: width: 64 }}" alt="Feature Icon">
          {% endif %}
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Image Icon Box",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The World’s ONLY<br>Doctor-Developed Sauna"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Feature Text",
          "default": "Developed with 48<br>Medical Doctors"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Image Icon Box",
      "category": "Custom",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "text": "Developed with 48<br>Medical Doctors"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Over 10 Years of<br>Clinical Research"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Real Medical<br>Benefits"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Hand-Assembled in<br>the USA"
          }
        }
      ]
    }
  ]
}
{% endschema %}
