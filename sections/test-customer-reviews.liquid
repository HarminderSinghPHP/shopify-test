{%- style -%}
    @media screen and (max-width: 750px) {
  .designer-content {
      font-size: 14px !important;
      line-height: 22px !important;
  }

  }
{% endstyle %} 
<section class="w3_bg {{ section.settings.addclass }}" id="reviews-views" >
    <div class="acc-bg-blue w3_bg">
      <div class="container w3_bg">
        <div class="feature-h-text collapsed w3_bg" data-toggle="collapse" data-target="#{{ section.id }}">
          <h4 class=" head-a1 addnewcl">{{ section.settings.heading }} <span>{{ section.settings.headblue }}</span> </h4>
            <i class="fa fa-angle-up head-arrow arrow-gray"></i>
        </div>
      </div>
    </div>
          <div class="container collapsed in real-review w3_bg" id="{{ section.id }}" style="margin-top:{{ section.settings.mtop }}PX; margin-bottom:{{ section.settings.mbottom }}PX">
            <div class="row w3_bg">
              <div class="col-md-9 padding-0 w3_bg">
                <h4 class="newinsert font-style">{{ section.settings.textone }} <span>{{ section.settings.textriew }}</span></h4>
                <p class="font-style_color">{{ section.settings.textcontent }}</p>
              </div>
              <div class="col-md-3 w3_bg"><img width="620" height="300" src="{{ section.settings.reviews | img_url:'master' }}" alt="medical sauna's - reviews" class="img-responsive" ></div>
            </div>
            <br>

            
            {% for block in section.blocks %}
            <div class="col-md-12 col-sm-12 col-xs-12 w3_bg" style="padding:0px; margin:0px;">
              <div class="Drreconnendation w3_bg" style="background-color:#F5F5F5;">
                <div class="col-md-12 col-sm-12 col-xs-12 w3_bg" style="margin:0px; ">
                  <h5 style="padding:0px;"><strong style="color:#000; font-size:14px;font-family: 'Ubuntu', sans-serif;">{{ block.settings.name }}<span style="color:#0096D9;">{{ block.settings.colname }}</span></strong></h5>
                  <p>{{ block.settings.colcontent }}</p>
                </div>
              </div>
            </div>
            {% endfor %}

          </div>
        </section>
{% schema %}
  {
   "name": "test-customer reviews",
    "settings": [
      {
        "type": "text",
        "id":"addclass",
        "label":"addclass"
      },
       {
        "type": "text",
        "id":"heading",
        "label":"Main Heading"
      },
      {
        "type": "text",
        "id":"headblue",
        "label":"White text"
      },
      {
        "type": "text",
        "id":"textone",
        "label":"Content Heading"
      },
      {
        "type": "text",
        "id":"textriew",
        "label":"Review"
      },
      {
        "type": "text",
        "id":"textcontent",
        "label":"Content"
      },
      {
         "type": "image_picker",
        "id":"reviews",
        "label":"Rating Image"
      }, {
          "type": "text",
          "id": "mtop",
          "label": "Margin top (PX)"
        },
      {
          "type": "text",
          "id": "mbottom",
          "label": "Margin Bottom (PX)"
        }
    ],
    "blocks": [
      {
        "type":"review",
        "name":"review",
        "limit":50,
        "settings": [
              {
             "type": "text",
             "id":"name",
             "label":"Name"
             },
             {
             "type": "text",
             "id":"colname",
             "label":"Coloured Name"
             },
              {
             "type": "text",
             "id":"colcontent",
             "label":"Review content"
             }
        ]
      }
    ],
    "presets":[
      {
        "name": "test-customer reviews"
      }
    ]
  }
{% endschema %}