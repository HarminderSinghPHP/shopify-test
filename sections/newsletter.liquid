<section class="newsletter-section text-center" style="margin-bottom:var(--spacing-sections); background:{{ section.settings.background }};padding:60px 20px;">
  <div class="container">
    {% if section.settings.heading != blank %}<h2 class="heading-font">{{ section.settings.heading }}</h2>{% endif %}
    {% if section.settings.subtext != blank %}<p>{{ section.settings.subtext }}</p>{% endif %}

    {% form 'customer', class: 'newsletter-form' %}
      {% if form.posted_successfully? %}
        <p class="form-success">Thanks for subscribing!</p>
      {% endif %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="newsletter-input-group">
        <input type="email" name="contact[email]" placeholder="Enter your email" required>
        <button type="submit" class="btn btn-primary">{{ section.settings.button_label }}</button>
      </div>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join our newsletter" },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Get 10% off your first order." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "color", "id": "background", "label": "Background color", "default": "#F5F5F5" }
  ],
  "presets": [ { "name": "Newsletter" } ]
}
{% endschema %}
