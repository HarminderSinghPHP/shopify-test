<section class="middle-content">
    <div class="container">
      <div class="row">
        <div class="col-md-9">
          <h4 class="newinsert font-style">{{ section.settings.heading }} <span>{{ section.settings.headblue }}</span></h4>
          <p class="font-style_color">{{ section.settings.textcontent }}</p>

        </div>

        <div class="col-md-3"><img src="{{ section.settings.reviews | img_url:'master' }}" alt="medicalsaunas traditional8plus - reviews" class="img-responsive"></div>

      </div>
      <br>
{% for block in section.blocks %}
      <div class="col-md-12 col-sm-12 col-xs-12 review-text" style="padding:0px; margin:0px;">
        <div class="Drreconnendation" style="background-color:#F5F5F5;">
          <div class="col-md-12 col-sm-12 col-xs-12" style="margin:0px; ">
            <h5><strong class="review-textsize">{{ block.settings.name }}<span>{{ block.settings.colname }}</span></strong></h5>
            <p>{{ block.settings.colcontent }}</p>
          </div>
        </div>
      </div>
{% endfor %}
      
    </div>
  </section>
  {% schema %}
  {
    "name": "trad-9 reviews",
    "settings": [
      {
        "type": "text",
        "id":"heading",
        "label":"Main Heading"
      },
      {
        "type": "text",
        "id":"headblue",
        "label":"White text"
      },
      {
        "type": "text",
        "id":"textcontent",
        "label":"Content Heading"
      },
      {
         "type": "image_picker",
        "id":"reviews",
        "label":"Rating Image"
      }
    ],
    "blocks": [
      {
        "type":"review",
        "name":"review",
        "limit":50,
        "settings": [
              {
             "type": "text",
             "id":"name",
             "label":"Name"
             },
             {
             "type": "text",
             "id":"colname",
             "label":"Coloured Name"
             },
              {
             "type": "text",
             "id":"colcontent",
             "label":"Review content"
             }
        ]
      }
    ],
    "presets":[
      {
       "name": "trad-9 reviews" 
      }
    ]
  }
{% endschema %}