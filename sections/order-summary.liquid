  $(".confirm-button").click(async function () {
    try {
        const orderDetailsResponse = await fetch(`https://api.medicalsaunas.com/order-details?order_id=${orderId}`);
        const orderData = await orderDetailsResponse.json();
        if (orderData.metafields?.some(meta => meta.namespace === "custom" && meta.key === "user_confirmation")) {
            window.location.href = "/pages/order-confirmation-error"; 
            return;
        }
        const userAgent = navigator.userAgent;
        const userData = {
            userAgent: userAgent,
            confirmationTime: new Date().toISOString()
        };

        const confirmResponse = await fetch("https://api.medicalsaunas.com/confirm-order", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ order_id: orderId, user_data: userData })
        });

        const confirmResult = await confirmResponse.json();
        if (confirmResult.success) {
            window.location.href = `/pages/thank-you-1?order-id=${orderId}`;
        } else {
           window.location.href = `/pages/order-confirmation-error`;
        }
    } catch (error) {
        console.error("Error confirming shipping:", error);
    }
});
});
