<script>
$(document).ready(async function () {
  const urlParams = new URLSearchParams(window.location.search);
const orderId = urlParams.get("order-id");

if (!orderId) {
    alert("Order ID is missing!");
    return;
}

try {
    const response = await fetch(`https://api.medicalsaunas.com/order-details?order_id=${orderId}`);
    const orderData = await response.json();
    const drrecOrderId = orderData.note_attributes.find(attr => attr.name === "drrec_order_id").value;
    const totalorderAmount = orderData.note_attributes.find(attr => attr.name === "total_amount").value;
    $("#order-id").text(drrecOrderId);
    $("#product-name").text(orderData.line_items?.[0]?.title || "N/A");
    $("#order-date").text(new Date(orderData.created_at).toLocaleDateString() || "N/A");
    $("#order-amount").html(`<span>${orderData.currency}</span><span>${totalorderAmount}</span>` || "N/A");
    $("#customer-name").text(orderData.customer?.first_name + " " + orderData.customer?.last_name || "N/A");
    $("#customer-name-head").text(orderData.customer?.first_name + " " + orderData.customer?.last_name || "N/A");
    $("#customer-email").text(orderData.customer?.email || "N/A");
    $("#customer-phone").text(orderData.shipping_address?.phone || "N/A");
    const customerFullName = `${orderData.customer?.first_name || ''} ${orderData.customer?.last_name || ''}`.trim();
   const shippingAddress = orderData.shipping_address
      ? [orderData.shipping_address.address1, orderData.shipping_address.city, orderData.shipping_address.zip, orderData.shipping_address.country]
          .filter(value => value && value.trim() !== '') 
          .join(', ')
      : "No shipping address available";
    $("#customer_address").html(`
      <li>${customerFullName}</li>
      <li>${shippingAddress}</li>
    `);

} catch (error) {
    console.error("Failed to fetch order details:", error);
}

