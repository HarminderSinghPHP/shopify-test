<style>

    .coldplung_mp{
      width:95%;
      margin: auto;
    }
  
      .card {
        position: relative;
        background: url('https://cdn.shopify.com/s/files/1/0897/8953/0400/files/product_cardcoldp.png?v=1745482044') no-repeat center center/cover;
        padding: 2rem;
        height: 619px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
      }
  
     .overlay {
      /* background: linear-gradient(to top, rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.3)); */
      padding: 2rem;
      border-radius: 1rem;
    }

    .subanner-a5 {
         position: absolute;
        top: 15px;
        right: 0;
        background: #bfff00;
        color: black;
        font-weight: 500;
        padding: 6px 15px 6px 20px;
        border-radius: 20px 0px 0px 20px;
        font-size: 24px;
    }
     .sub-banner-a1 {
        text-align: start;
        text-transform: uppercase;
        font-size: 22px;
        margin: 1rem 0;
        line-height: 28px;
        display: grid;
        color: white;
    }
    
    .subanner-a2 {
        display: flex;
        align-items: center;
        gap: 9px;
        font-size: 16px;
        color: white;
        margin-bottom: 25px;
    }
      .subanner-a2 strong {
        font-size: 32px;
      }
    .subanner-a3 {
        padding: 16px 20px 16px 20px;
        font-size: 16px;
        color: white;
        text-transform: uppercase;
        cursor: pointer;
        background: #0987cc;
        font-weight: 600;
        border: none;
        border-radius: 6px;
    }
    .subanner-a4 {
        display: grid;
        font-size: 60px;
        font-weight: bold;
        margin-bottom: 1rem !important;
        line-height: 1.2;
        margin-top: 0px !important;
        margin: 0px;
        color: white;
    }
      a.subanner-a3:hover {
        color: white;
    }


    @media (max-width: 768px) {
       .card {
        background: url('https://cdn.shopify.com/s/files/1/0897/8953/0400/files/product_cardcoldp.png?v=1745480752') no-repeat center center/cover;
      }
  
      .subanner-a5 {
          position: absolute;
          top: 15px;
          right: 0;
          background: #bfff00;
          color: black;
          font-weight: bold;
          padding: 3px 8px 3px 14px !important;
          border-radius: 20px 0px 0px 20px;
          font-size: 14px !important;
      }
      
       .subanner-a4 {
          display: grid;
          font-size: 36px;
          font-weight: bold;
          margin-bottom: 0px !important;
          line-height: 1.2;
          margin-top: 0px !important;
          margin: 0px;
      }
      .sub-banner-a1 {
          text-align: start;
          text-transform: uppercase;
          font-size: 16px;
          margin: 1rem 0;
          line-height: 22px;
          display: block;
      }
      
       .subanner-a3 {
              padding: 12px 28px 12px 19px;
              font-size: 14px;
          border-radius: 8px;
      }
        
      .card {
        padding: 1rem;
        background-position: center right;
      }

      .overlay {
        padding: 1rem;
      }

      h1 {
        font-size: 1.8rem;
      }

      .price {
        font-size: 1.2rem;
      }

      .btn {
        width: 100%;
        text-align: center;
      }

      .subanner-a5 {
        font-size: 0.8rem;
        padding: 0.4rem 0.8rem;
      }
    }
    @media (max-width: 375px) {
      .subanner-a3 {
          padding: 12px 8px 12px 8px;
          font-size: 14px;
      }
  
      .subanner-a4 {
          font-size: 24px;
      }
        .sub-banner-a1 {
          font-size: 14px;
          line-height: 18px;
      }
      
    }
</style>
 <!-- product _05  -->
    {% assign selected_product_handle = section.settings.custom_products5 %}
    {% assign product_05 = all_products[selected_product_handle] %}

    
<div class="coldplung_mp">
    <div class="card">
        <div class="subanner-a5">
          {% if product_05.compare_at_price > product_05.price %}
            {% assign save_amount = product_05.compare_at_price | minus: product_05.price %}
            <span class="">SAVE {{ save_amount | money_without_trailing_zeros }}</span>
          {% endif %}  
        </div>
        <div class="overlay">
            <h1 class="subanner-a4">Cold Plunge Meets<spa> Aromatherapy</spa></h1>
            <p class="sub-banner-a1">Experience cold therapy and essential oil steam with
                <span>
        FROZEN<sup> ™</sup> —engineered to heal, recharge, and restore.</span></p>
            <div class="subanner-a2">Starting at <strong>{{ product_05.price | money_without_trailing_zeros}}</strong></div>
            <a href="collections/frozen-cold-plunges" class="subanner-a3">Explore Frozen™ Cold Plunges</a>
        </div>
    </div>
</div>
{% schema %}
    {
        "name":"subanner180425",
        "tag":"section",
        "class":"custom-banner",
        "settings": [
                {
                  "type": "product",
                  "id": "custom_products5",
                  "label": "Select products"
                }                
        ],
        "presets":[
           {
              "name":"subanner180425"
           }
        ]
     }
{% endschema %}
