      "settings":[
         {
      "type": "text",
      "id": "ID_New",
      "label": "ID",
      "info": "DO Not Touch or Edit ID"
    },
        {
                "type":"image_picker",
                "id":"icon0123",
                "label":"Icon"
             },
        {
      "type":"text",
      "id":"icontext0123",
      "label":"Icon Text"
   },
    
  {
      "type":"image_picker",
      "id":"text0125",
      "label":"image"
   },
  {
      "type":"textarea",
      "id":"heading_new12",
      "label":"Heading"
   },
  {
      "type":"textarea",
       "id":"desc0123",
      "label":"description"
   } 
    ]
       }

    ],

    
    "presets": [{
      "name": "custom product blocks"
    }]
  }
{% endschema %}