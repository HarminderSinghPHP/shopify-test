    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button-text",
      "default": "Click Me"
    },
  ],
 
  "presets": [
    {
      "name": "collection-image-010525",
      "category": "Custom"
    }
  ]
}
{% endschema %}