<!-- grid-section-started-here -->
<section class="collection-grid">
  <div class="grid-position-a1 ">
      <img class="grid-desktop-img" src="{{ section.settings.desktop-image | img_url:'master' }}" />
      <img class="grid-mobile-img" src="{{ section.settings.mobile-image | img_url:'master' }}"   />
      
    <div class="grid-position-in"> 
      <h2 class="position-h2">{{ section.settings.heading }}</h2>
      <p class="position-p">{{ section.settings.paragraph_text }}</p>

      <p class="grid-button"><a>SHOP MEDICAL SAUNA <span>™</span></a></p>
    
    </div>
  </div>
  <div class="grid-position-a2">
      <img class="grid-desktop-img" src="{{ section.settings.desktop-image1 | img_url:'master' }}" />
      <img class="grid-mobile-img" src="{{ section.settings.mobile-image | img_url:'master' }}"   />
    <div class="grid-position-in"> 
      <h2 class="position-h2">{{ section.settings.heading }}</h2>
      <p class="position-p">{{ section.settings.paragraph_text }}</p>

      <p class="grid-button"><a>SHOP MEDICAL SAUNA <span>™</span></a></p>
    
  </div>
  </div>
</section>

<!-- grid-section-ended-here -->
  
<style>
.collection-grid{
  display: flex;
 justify-content: space-around;
}
.grid-position-a1 {
    width: 50%;
    text-align: center;
    position: relative;
}
.grid-position-a2 {
    width: 50%;
    text-align: center;
    position: relative;
}  
.grid-desktop-img {
   desktop:block;
   width:90%;
}
.grid-mobile-img{
  display:none;
}
.grid-position-in {
    position: absolute;
    top: 170px;
    left: 40px;
    /* background-image: linear-gradient(to bottom, #00000005, #413e3eb8, black); */
    width: 90%;
}
  
.position-h2{
      font-size: 30px;
    font-weight: bold;
    color: #fff;
} 
.grid-button {
  border: 2px solid #0096d9;
    width: fit-content;
    padding: 12px;
    background-color: #0096d9;
    font-weight: 700;
    font-size: 16px;
  border-radius: 8px;
} 
.grid-button a {
  color: #fff;
}  
 .background {
      position: relative;
      width: 100%;
      height: auto;
      background: 
        linear-gradient(to bottom, #00000005, #413e3eb8, black), 
        url('https://medicalsaunas.com/cdn/shop/files/series_d83d79a3-ad8e-498c-9792-721fd37ff858.png?v=1747041031') no-repeat center center / cover;
    }  
  @media only screen and (max-width: 768px) {
    .grid-desktop-img {
   desktop:none;
   width:100%;
}
  .grid-mobile-img{
  display:none;
} 

  }
</style>
{% schema %}
{
  "name": "collection-image-010525",
  "settings": [

     {
          "type": "image_picker",
          "id": "mobile-image",
          "label": "mobile-image"
        },
    {
          "type": "image_picker",
          "id": "desktop-image",
          "label": "desktop-image"
        },
      {
          "type": "image_picker",
          "id": "mobile-image1",
          "label": "mobile-image"
        },
    {
          "type": "image_picker",
          "id": "desktop-image1",
          "label": "desktop-image"
        },
    
    {
      "type": "text",
      "id": "heading",
