<style>
  #shopify-section-{{ section.id }} .section {
    margin-bottom: 32px;
  }
  .qck-video-container {
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    line-height: 0;
  }
  .qck-video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
  }
  .qck-video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
    max-height: calc(1000px * 0.5625);
  }
  @media only screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .section {
      margin-bottom: 64px;
    }
  }
</style>

<section class="qck-product-video section section--{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="qck-video-container">
    <div class="qck-video-wrapper">
      <iframe 
        src="{{ section.settings.video_url }}" 
        title="YouTube video" 
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
        allowfullscreen>
      </iframe>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "QCK Video",
    "settings": [
      {
        "type": "url",
        "id": "video_url",
        "label": "Video Embed URL"
      }
    ],
    "presets": [{
      "name": "QCK Video"
    }]
  }
{% endschema %}