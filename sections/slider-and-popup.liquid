<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tiny-slider/2.9.2/tiny-slider.css">

<section class="main-section">
  <div class="container">
    <div class="maiun-secunmd">
      <div class="row">
        <div class=" col-md-6 custom-tabs">
          <h2 class="text-hadding-h2">{{ section.settings.main_heading }}</h2>
          <h4 class="text-h4">{{ section.settings.sub_heading }}<sup class="span001">{{ section.settings.superscript_text }}</sup></h4>

          <div class="tabs001">
            <div class="site-main-tab">
              <div class="tab">
                <button class="tablinks" onclick="openCity(event, 'exterior')">{{ section.settings.tab_1 }}</button>
                <button class="tablinks" onclick="openCity(event, 'interior')">{{ section.settings.tab_2 }}</button>
              </div>
            </div>

            <div id="exterior" class="tabcontent">
              <ul class="control" id="custom-control">
                <li class="prev"><i class="fa-solid fa-arrow-left"></i></li>
                <li class="next"><i class="fa-solid fa-arrow-right"></i></li>
              </ul>

              <div class="my-slider">
                {% for block in section.blocks %}
                  {% if block.type == "slide" and block.settings.tab_group == "exterior" %}
                  <div class="slide-item">
                    <img src="{{ block.settings.image | image_url: width: 600 }}" alt="">
                    <h2 class="text-hadding">{{ block.settings.title }}</h2>
                    <p class="pragraph-textslider">{{ block.settings.description }}</p>
                  </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>

            <div id="interior" class="tabcontent">
              <ul class="control" id="custom-control">
                <li class="prev"><i class="fa-solid fa-arrow-left"></i></li>
                <li class="next"><i class="fa-solid fa-arrow-right"></i></li>
              </ul>

              <div class="my-slider-two">
                {% for block in section.blocks %}
                  {% if block.type == "slide" and block.settings.tab_group == "interior" %}
                  <div class="slide-item">
                    <img src="{{ block.settings.image | image_url: width: 600 }}" alt="">
                    <h2 class="text-hadding">{{ block.settings.title }}</h2>
                    <p class="pragraph-textslider">{{ block.settings.description }}</p>
                  </div>
                  {% endif %}
                {% endfor %}
              </div>
            </div>

          </div>
        </div>

        <div class="col-md-6 cutom-bg-img">
          <div class="Solidbg-image">
            {% assign popup_index = 0 %}
            {% for block in section.blocks %}
              {% if block.type == "slide" %}
                {% assign popup_index = popup_index | plus: 1 %}
                <div class="icon-plus-img{{ popup_index }}">
                  <a href="#" data-bs-toggle="modal" data-bs-target="#popup{{ popup_index }}"><i class="fa-solid fa-plus"></i></a>
                </div>
              {% endif %}
            {% endfor %}

            {% assign popup_index = 0 %}
            {% for block in section.blocks %}
              {% if block.type == "slide" %}
              {% assign popup_index = popup_index | plus: 1 %}
              <div class="modal fade" id="popup{{ popup_index }}" tabindex="-1" aria-labelledby="popup{{ popup_index }}Label" aria-hidden="true">
                <div class="modal-dialog">
                  <div class="img-clickon-popup">
                    <img src="{{ block.settings.image | image_url: width: 600 }}" alt="">
                  </div>
                  <div class="modal-content">
                    <div class="modal-header">
                      <h5 class="modal-title" id="popup{{ popup_index }}Label">{{ block.settings.title }}</h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                      {{ block.settings.description }}
                    </div>
                  </div>
                </div>
              </div>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/tiny-slider/2.9.2/min/tiny-slider.js"></script>
<script>
  function openCity(evt, cityName) {
    var i, tabcontent, tablinks;
    tabcontent = document.getElementsByClassName("tabcontent");
    for (i = 0; i < tabcontent.length; i++) {
      tabcontent[i].style.display = "none";
    }
    tablinks = document.getElementsByClassName("tablinks");
    for (i = 0; i < tablinks.length; i++) {
      tablinks[i].className = tablinks[i].className.replace(" active", "");
    }
    document.getElementById(cityName).style.display = "block";
    evt.currentTarget.className += " active";
  }

  document.addEventListener("DOMContentLoaded", function () {
    var firstTab = document.querySelector(".tablinks");
    if (firstTab) firstTab.click();

    tns({
      container: ".my-slider",
      items: 1,
      gutter: 20,
      slideBy: 1,
      startIndex: 0,
      controls: true,
      nav: false,
      mouseDrag: true,
      autoplay: true,
      autoplayButtonOutput: false,
      controlsContainer: "#custom-control",
      responsive: {
        0: { items: 1 },
        768: { items: 1 },
        1440: { items: 1 }
      }
    });

    tns({
      container: ".my-slider-two",
      items: 1,
      gutter: 20,
      slideBy: 1,
      startIndex: 0,
      controls: true,
      nav: false,
      mouseDrag: true,
      autoplay: true,
      autoplayButtonOutput: false,
      controlsContainer: "#custom-control",
      responsive: {
        0: { items: 1 },
        768: { items: 1 },
        1440: { items: 1 }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Slider and Popup",
  "settings": [
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "Explore Your Sauna"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "Nature 8Plus"
    },
    {
      "type": "text",
      "id": "superscript_text",
      "label": "Superscript Text",
      "default": "TM"
    },
    {
      "type": "text",
      "id": "tab_1",
      "label": "Tab 1 Label",
      "default": "exterior"
    },
    {
      "type": "text",
      "id": "tab_2",
      "label": "Tab 2 Label",
      "default": "interior"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Natural Cedar Build"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Built with Natural Red Cedar—designed to last, heal, and grow stronger over time."
        },
        {
          "type": "select",
          "id": "tab_group",
          "label": "Tab Group",
          "default": "exterior",
          "options": [
            { "value": "exterior", "label": "Exterior" },
            { "value": "interior", "label": "Interior" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slider and Popup",
      "category": "Custom"
    }
  ]
}
{% endschema %}
