<!-- section-name.liquid -->
<section id="{{ section.id }}" class="{{ section.settings.addclass }} fly">
  <div class="image-position">
      <img class="image-00 desktop-images-position" src="{{ section.settings.desktop-image | img_url:'master' }}" />
      <img class="image-05 mobile-images-position" src="{{ section.settings.mobile-image | img_url:'master' }}"   />
  <div class="inner-image-position-a">
  <!-- traditional-saunas-started-here -->
  <!-- desktop-text-started -->
  <div class="desktop-text-hide">
   
    <h1 class="head-m1">{{ section.settings.heading }} </h1>
     <p class="para-m1">{{ section.settings.paragraph_text }} <span></span></p>
    <a href="{{ section.settings.button_link }}" class="">
  <p class="shopnow-button">{{ section.settings.button_text }}</p>
</a>
