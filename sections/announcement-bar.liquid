{% style %}
  #shopify-section-{{ section.id }} .announcement-bar {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: {{ section.settings.font.family }}, {{ section.settings.font.fallback_families }};
    font-weight: {{ section.settings.font.weight }};
    font-size: {{ section.settings.font_size }}px;
  }
  #shopify-section-{{ section.id }} .announcement-slider {
    text-align: {{ section.settings.text_align }};
  }
  {{ section.settings.font | font_face: font_display: 'swap' }}
{% endstyle %}

<div class="announcement-bar" style="background:{{ section.settings.background }};color:{{ section.settings.text_color }};">
  <div class="container announcement-bar-inner">

    {% if section.settings.show_social %}
      <div class="announcement-social">
        {% if settings.social_facebook != blank %}<a href="{{ settings.social_facebook }}" aria-label="Facebook">{% render 'icon', name: 'facebook' %}</a>{% endif %}
        {% if settings.social_instagram != blank %}<a href="{{ settings.social_instagram }}" aria-label="Instagram">{% render 'icon', name: 'instagram' %}</a>{% endif %}
        {% if settings.social_twitter != blank %}<a href="{{ settings.social_twitter }}" aria-label="Twitter">{% render 'icon', name: 'twitter' %}</a>{% endif %}
      </div>
    {% endif %}

    <div class="announcement-slider" data-announcement-slider data-autoplay-speed="{{ section.settings.autoplay_speed }}">
      <div class="announcement-slider-track" data-announcement-track>
        {% for block in section.blocks %}
          {% case block.type %}

            {% when 'message' %}
              <div class="announcement-slide" data-announcement-slide {{ block.shopify_attributes }}>
                {% if block.settings.link != blank %}
                  <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
                {% else %}
                  <span>{{ block.settings.text }}</span>
                {% endif %}
              </div>

            {% when 'countdown' %}
              <div class="announcement-slide announcement-countdown-slide" data-announcement-slide {{ block.shopify_attributes }}>
                <span class="countdown-inner">
                  {% if block.settings.label != blank %}<span class="countdown-label">{{ block.settings.label }}</span>{% endif %}
                  <span
                    class="countdown-timer"
                    data-countdown-timer
                    data-countdown-end="{{ block.settings.end_datetime }}"
                    data-countdown-expired-text="{{ block.settings.expired_message | escape }}"
                  >
                    <span class="countdown-unit"><span data-cd-days>00</span><small>d</small></span>
                    <span class="countdown-unit"><span data-cd-hours>00</span><small>h</small></span>
                    <span class="countdown-unit"><span data-cd-mins>00</span><small>m</small></span>
                    <span class="countdown-unit"><span data-cd-secs>00</span><small>s</small></span>
                  </span>
                </span>
              </div>

          {% endcase %}
        {% endfor %}
      </div>
    </div>

    {% if section.settings.secondary_menu != blank %}
      <nav class="announcement-secondary-menu">
        <ul>
          {% for link in section.settings.secondary_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </nav>
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "checkbox", "id": "show_social", "label": "Show social icons", "default": true },
    { "type": "link_list", "id": "secondary_menu", "label": "Secondary menu (e.g. Help, Track order)" },

    { "type": "header", "content": "Slider" },
    { "type": "range", "id": "autoplay_speed", "min": 2, "max": 15, "step": 1, "unit": "s", "label": "Time per slide", "default": 5, "info": "Only applies when there is more than one slide block below." },

    { "type": "header", "content": "Style" },
    { "type": "select", "id": "text_align", "label": "Text alignment", "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ], "default": "center" },
    { "type": "font_picker", "id": "font", "label": "Font", "default": "helvetica_n4" },
    { "type": "range", "id": "font_size", "min": 10, "max": 24, "step": 1, "unit": "px", "label": "Font size", "default": 14 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Padding top", "default": 10 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Padding bottom", "default": 10 },
    { "type": "color", "id": "background", "label": "Background color", "default": "#1A1A1A" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message slide",
      "settings": [
        { "type": "text", "id": "text", "label": "Message", "default": "Sale up to 50% OFF on selected items" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    },
    {
      "type": "countdown",
      "name": "Countdown timer slide",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Sale ends in:" },
        { "type": "text", "id": "end_datetime", "label": "End date & time", "info": "Format: YYYY-MM-DDTHH:MM, e.g. 2026-12-31T23:59 (24-hour clock, your store's local time)." },
        { "type": "text", "id": "expired_message", "label": "Message shown after it ends", "default": "Offer has ended" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [
        { "type": "message" }
      ]
    }
  ]
}
{% endschema %}
