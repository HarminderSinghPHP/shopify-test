{% style %}
  
  #shopify-section-{{ section.id }} .header-logo-row {
    {% if section.settings.top_row_bg_color != blank %}background-color: {{ section.settings.top_row_bg_color }};{% endif %}
    {% if section.settings.top_row_text_color != blank %}color: {{ section.settings.top_row_text_color }};{% endif %}
    padding-top: {{ section.settings.top_row_padding_top }}px;
    padding-bottom: {{ section.settings.top_row_padding_bottom }}px;
    font-family: {{ section.settings.top_row_font.family }}, {{ section.settings.top_row_font.fallback_families }};
    font-weight: {{ section.settings.top_row_font.weight }};
  }

  #shopify-section-{{ section.id }} .header-inner {
    {% if section.settings.bottom_row_bg_color != blank %}background-color: {{ section.settings.bottom_row_bg_color }};{% endif %}
    padding-top: {{ section.settings.bottom_row_padding_top }}px;
    padding-bottom: {{ section.settings.bottom_row_padding_bottom }}px;
    font-family: {{ section.settings.bottom_row_font.family }}, {{ section.settings.bottom_row_font.fallback_families }};
    font-weight: {{ section.settings.bottom_row_font.weight }};
  }
  {% if section.settings.bottom_row_text_color != blank %}
    #shopify-section-{{ section.id }} .header-inner,
    #shopify-section-{{ section.id }} .header-inner a,
    #shopify-section-{{ section.id }} .header-inner .icon-btn,
    #shopify-section-{{ section.id }} .header-inner .icon-btn svg {
      color: {{ section.settings.bottom_row_text_color }};
      fill: {{ section.settings.bottom_row_text_color }};
    }
  {% endif %}

  #shopify-section-{{ section.id }} .header-inline-search {
    max-width: {{ section.settings.search_bar_width }}px;
    flex: 0 1 auto;
  }
  #shopify-section-{{ section.id }} .header-inline-search input {
    {% if section.settings.search_bar_bg_color != blank %}background-color: {{ section.settings.search_bar_bg_color }};{% endif %}
    {% if section.settings.search_bar_text_color != blank %}color: {{ section.settings.search_bar_text_color }};{% endif %}
    {% if section.settings.search_bar_border_color != blank %}border-color: {{ section.settings.search_bar_border_color }};{% endif %}
  }

  #shopify-section-{{ section.id }} .mega-menu {
    max-width: {{ section.settings.mega_menu_width }}px;
    padding: {{ section.settings.mega_menu_padding }}px;
    border-radius: {{ section.settings.mega_menu_border_radius }}px;
    background-color: {{ section.settings.mega_menu_bg_color | default: '#ffffff' }};
    border: 1px solid {{ section.settings.mega_menu_border_color | default: 'transparent' }};
    {% case section.settings.mega_menu_shadow %}
      {% when 'soft' %}box-shadow: 0 8px 24px rgba(0,0,0,0.08);
      {% when 'strong' %}box-shadow: 0 16px 40px rgba(0,0,0,0.18);
    {% endcase %}
  }

  {{ section.settings.top_row_font | font_face: font_display: 'swap' }}
  {{ section.settings.bottom_row_font | font_face: font_display: 'swap' }}
{% endstyle %}

<header class="site-header mobile-header-mode-{{ section.settings.mobile_header_style }}" style="background:var(--color-header-bg);border-bottom:1px solid var(--color-border);" data-sticky="{{ section.settings.sticky_header }}">
  <div class="container header-outer">

    <button class="mobile-menu-toggle" aria-label="Menu" data-drawer-open="mobile-menu">
      {% render 'icon', name: 'menu' %}
    </button>

    {% if section.settings.logo_layout == 'stacked' %}
      {% comment %} Logo sits alone in its own row, aligned per logo_position {% endcomment %}
      <div class="header-logo-row header-align-{{ section.settings.logo_position }}">
        {% render 'header-logo' %}
      </div>
    {% endif %}
 
    <div class="header-inner">
      <div class="header-zone header-zone-left">
        {% if section.settings.logo_layout == 'inline' and section.settings.logo_position == 'left' %}{% render 'header-logo' %}{% endif %}
        {% if section.settings.menu_position == 'left' %}{% render 'header-menu', menu_type: section.settings.menu_type, blocks: section.blocks %}{% endif %}
        {% if section.settings.show_search_bar and section.settings.search_position == 'left' %}{% render 'header-search' %}{% endif %}
        {% if section.settings.icons_position == 'left' %}{% render 'header-icons', show_search_bar: section.settings.show_search_bar %}{% endif %}
      </div>
      <div class="header-zone header-zone-center">
        {% if section.settings.logo_layout == 'inline' and section.settings.logo_position == 'center' %}{% render 'header-logo' %}{% endif %}
        {% if section.settings.menu_position == 'center' %}{% render 'header-menu', menu_type: section.settings.menu_type, blocks: section.blocks %}{% endif %}
        {% if section.settings.show_search_bar and section.settings.search_position == 'center' %}{% render 'header-search' %}{% endif %}
        {% if section.settings.icons_position == 'center' %}{% render 'header-icons', show_search_bar: section.settings.show_search_bar %}{% endif %}
      </div>
      <div class="header-zone header-zone-right">
        {% if section.settings.logo_layout == 'inline' and section.settings.logo_position == 'right' %}{% render 'header-logo' %}{% endif %}
        {% if section.settings.menu_position == 'right' %}{% render 'header-menu', menu_type: section.settings.menu_type, blocks: section.blocks %}{% endif %}
        {% if section.settings.show_search_bar and section.settings.search_position == 'right' %}{% render 'header-search' %}{% endif %}
        {% if section.settings.icons_position == 'right' %}{% render 'header-icons', show_search_bar: section.settings.show_search_bar %}{% endif %}
      </div>
    </div>

    {% comment %} Dedicated mobile-only bar: hamburger / search / centered logo / account / cart.
                   Only shown when "Mobile header style" is set to "Simple bar" below. {% endcomment %}
    <div class="mobile-header-bar">
      <button class="mobile-menu-toggle" aria-label="Menu" data-drawer-open="mobile-menu">
        {% render 'icon', name: 'menu' %}
      </button>
      {% if section.settings.mobile_show_search_icon %}
        <button class="icon-btn" data-drawer-open="search-drawer" aria-label="Search">{% render 'icon', name: 'search' %}</button>
      {% endif %}
      <div class="mobile-header-logo">{% render 'header-logo' %}</div>
      <div class="mobile-header-icons">
        {% if section.settings.mobile_show_account_icon %}
          <a class="icon-btn" href="{{ routes.account_url }}" aria-label="Account">{% render 'icon', name: 'account' %}</a>
        {% endif %}
        <button class="icon-btn cart-icon" {% if settings.cart_type == 'drawer' %}data-drawer-open="cart-drawer"{% else %}data-href="{{ routes.cart_url }}"{% endif %} aria-label="Cart">
          {% render 'icon', name: 'cart' %}
          <span class="cart-count" data-cart-count>{{ cart.item_count }}</span>
        </button>
      </div>
    </div>

  </div>
</header>

{% render 'mobile-menu', menu: section.settings.mobile_menu %}
{% render 'search-drawer',
  popular_search_menu: section.settings.search_popular_menu,
  popular_collections: section.settings.search_popular_collections,
  featured_products: section.settings.search_featured_products,
  categories_heading: section.settings.search_categories_heading,
  products_heading: section.settings.search_products_heading,
  search_product_limit: section.settings.search_product_limit
%}

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "range", "id": "logo_width", "min": 60, "max": 300, "step": 10, "unit": "px", "label": "Logo width", "default": 140 },
    { "type": "link_list", "id": "menu", "label": "Main menu (desktop)", "default": "main-menu" },
    { "type": "link_list", "id": "mobile_menu", "label": "Mobile menu (used only in the mobile drawer)", "default": "main-menu", "info": "Set this to a different menu if you want mobile to show different links than desktop." },
    { "type": "checkbox", "id": "sticky_header", "label": "Sticky header", "default": true },
    { "type": "header", "content": "Layout" },
    {
      "type": "select",
      "id": "logo_layout",
      "label": "Logo placement",
      "options": [
        { "value": "stacked", "label": "Own row, above the menu" },
        { "value": "inline", "label": "Same row as menu" }
      ],
      "default": "stacked"
    },
    {
      "type": "select",
      "id": "logo_position",
      "label": "Logo alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "menu_position",
      "label": "Menu alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "icons_position",
      "label": "Icons alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    { "type": "header", "content": "Search bar" },
    { "type": "checkbox", "id": "show_search_bar", "label": "Show inline search bar (instead of icon only)", "default": false },
    {
      "type": "select",
      "id": "search_position",
      "label": "Search bar alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "header", "content": "Menu type" },
    {
      "type": "select",
      "id": "menu_type",
      "label": "Menu type",
      "options": [
        { "value": "simple", "label": "Simple dropdown" },
        { "value": "mega", "label": "Mega menu (columns + image)" }
      ],
      "default": "simple",
      "info": "Mega menu applies to top-level menu items that have a matching 'Mega menu column' block below."
    },

    { "type": "header", "content": "Header width" },
    {
      "type": "select",
      "id": "header_width",
      "label": "Header width",
      "options": [
        { "value": "full", "label": "Full width (edge to edge)" },
        { "value": "contained", "label": "Contained (custom max-width)" }
      ],
      "default": "full"
    },
    { "type": "range", "id": "header_max_width", "min": 960, "max": 1600, "step": 20, "unit": "px", "label": "Max width (when Contained)", "default": 1200 },

    { "type": "header", "content": "Top row style (logo row)" },
    { "type": "color", "id": "top_row_bg_color", "label": "Background color" },
    { "type": "color", "id": "top_row_text_color", "label": "Text color" },
    { "type": "range", "id": "top_row_padding_top", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Padding top", "default": 16 },
    { "type": "range", "id": "top_row_padding_bottom", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Padding bottom", "default": 12 },
    { "type": "font_picker", "id": "top_row_font", "label": "Font", "default": "helvetica_n4" },

    { "type": "header", "content": "Bottom row style (menu row)" },
    { "type": "color", "id": "bottom_row_bg_color", "label": "Background color" },
    { "type": "color", "id": "bottom_row_text_color", "label": "Text / link color" },
    { "type": "range", "id": "bottom_row_padding_top", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Padding top", "default": 12 },
    { "type": "range", "id": "bottom_row_padding_bottom", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Padding bottom", "default": 12 },
    { "type": "font_picker", "id": "bottom_row_font", "label": "Font", "default": "helvetica_n4" },

    { "type": "header", "content": "Search bar style" },
    { "type": "range", "id": "search_bar_width", "min": 120, "max": 600, "step": 10, "unit": "px", "label": "Width", "default": 280 },
    { "type": "color", "id": "search_bar_bg_color", "label": "Background color" },
    { "type": "color", "id": "search_bar_text_color", "label": "Text color" },
    { "type": "color", "id": "search_bar_border_color", "label": "Border color" },

    { "type": "header", "content": "Mega menu style" },
    { "type": "range", "id": "mega_menu_width", "min": 480, "max": 1400, "step": 20, "unit": "px", "label": "Panel max-width", "default": 900 },
    { "type": "range", "id": "mega_menu_padding", "min": 0, "max": 60, "step": 2, "unit": "px", "label": "Padding", "default": 32 },
    { "type": "color", "id": "mega_menu_bg_color", "label": "Background color" },
    { "type": "color", "id": "mega_menu_border_color", "label": "Border color" },
    { "type": "range", "id": "mega_menu_border_radius", "min": 0, "max": 30, "step": 2, "unit": "px", "label": "Corner radius", "default": 12 },
    {
      "type": "select",
      "id": "mega_menu_shadow",
      "label": "Shadow",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "soft", "label": "Soft" },
        { "value": "strong", "label": "Strong" }
      ],
      "default": "soft"
    },
    {
      "type": "header",
      "content": "Search drawer content"
    },
    {
      "type": "link_list",
      "id": "search_popular_menu",
      "label": "Popular search terms menu",
      "info": "Menu links will appear as search suggestion buttons."
    },
    {
      "type": "collection_list",
      "id": "search_popular_collections",
      "label": "Popular collections",
      "limit": 6
    },
    {
      "type": "product_list",
      "id": "search_featured_products",
      "label": "Featured search products",
      "limit": 8
    },
    {
      "type": "text",
      "id": "search_categories_heading",
      "label": "Collections heading",
      "default": "Popular categories"
    },
    {
      "type": "text",
      "id": "search_products_heading",
      "label": "Products heading",
      "default": "Products"
    },
    {
      "type": "range",
      "id": "search_product_limit",
      "min": 2,
      "max": 10,
      "step": 1,
      "label": "Live search product limit",
      "default": 6
    },
    { "type": "header", "content": "Mobile header" },
    {
      "type": "select",
      "id": "mobile_header_style",
      "label": "Mobile header style",
      "options": [
        { "value": "responsive", "label": "Same as desktop (responsive)" },
        { "value": "simple_bar", "label": "Simple bar (menu \u00b7 search \u00b7 logo \u00b7 account \u00b7 cart)" }
      ],
      "default": "simple_bar",
      "info": "\"Simple bar\" is a separate, fixed mobile layout so you can style desktop and mobile independently."
    },
    { "type": "checkbox", "id": "mobile_show_search_icon", "label": "Show search icon on mobile bar", "default": true },
    { "type": "checkbox", "id": "mobile_show_account_icon", "label": "Show account icon on mobile bar", "default": true }
  ],
  "blocks": [
    {
      "type": "mega_column",
      "name": "Mega menu column",
      "settings": [
        { "type": "text", "id": "parent_label", "label": "Attach to menu item", "info": "Must exactly match a top-level menu item's title (e.g. 'Skincare')." },
        { "type": "text", "id": "heading", "label": "Column heading" },
        { "type": "link_list", "id": "column_menu", "label": "Column links" }
      ]
    },
    {
      "type": "mega_promo",
      "name": "Mega menu promo image",
      "settings": [
        { "type": "text", "id": "parent_label", "label": "Attach to menu item", "info": "Must exactly match a top-level menu item's title." },
        { "type": "image_picker", "id": "image", "label": "Promo image" },
        { "type": "text", "id": "heading", "label": "Promo heading" },
        { "type": "url", "id": "link", "label": "Promo link" }
      ]
    }
  ]
}
{% endschema %}
