<footer class="site-footer" style="background:var(--color-footer-bg);">
  <div class="container footer-inner">
    {% if settings.brand_image or settings.brand_headline != blank or settings.brand_description != blank %}
      <div class="footer-col footer-brand">
        {% if settings.brand_image %}
          <img src="{{ settings.brand_image | image_url: width: 200 }}" alt="{{ shop.name }}" class="footer-brand-image">
        {% endif %}
        {% if settings.brand_headline != blank %}
          <h4 class="heading-font">{{ settings.brand_headline }}</h4>
        {% endif %}
        {% if settings.brand_description != blank %}
          <div class="footer-brand-description footer-richtext">{{ settings.brand_description }}</div>
        {% endif %}
      </div>
    {% endif %}
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'text_column' %}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h4 class="heading-font">{{ block.settings.heading }}</h4>
            <div class="footer-richtext">{{ block.settings.content }}</div>
          </div>
        {% when 'link_list' %}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h4 class="heading-font">{{ block.settings.heading }}</h4>
            <ul>
              {% for link in block.settings.menu.links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% when 'newsletter' %}
          <div class="footer-col" {{ block.shopify_attributes }}>
            <h4 class="heading-font">{{ block.settings.heading }}</h4>
            <p>{{ block.settings.subtext }}</p>
            {% form 'customer', class: 'footer-newsletter-form' %}
              {% if form.posted_successfully? %}
                <p class="form-success">Thanks for subscribing!</p>
              {% endif %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <input type="email" name="contact[email]" placeholder="Your email" required>
              <button type="submit" class="btn btn-primary">Subscribe</button>
            {% endform %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>

  <div class="container footer-bottom">
    <div class="social-icons">
      {% if settings.social_instagram != blank %}<a href="{{ settings.social_instagram }}" aria-label="Instagram">{% render 'icon', name: 'instagram' %}</a>{% endif %}
      {% if settings.social_facebook != blank %}<a href="{{ settings.social_facebook }}" aria-label="Facebook">{% render 'icon', name: 'facebook' %}</a>{% endif %}
      {% if settings.social_twitter != blank %}<a href="{{ settings.social_twitter }}" aria-label="Twitter">{% render 'icon', name: 'twitter' %}</a>{% endif %}
      {% if settings.social_youtube != blank %}<a href="{{ settings.social_youtube }}" aria-label="YouTube">{% render 'icon', name: 'youtube' %}</a>{% endif %}
    </div>
    <p class="footer-copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "text_column",
      "name": "Text column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "About us" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Tell your store's story.</p>" }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Quick links" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Stay in the loop" },
        { "type": "text", "id": "subtext", "label": "Subtext", "default": "Sign up for updates and offers." }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "text_column" },
      { "type": "link_list" },
      { "type": "newsletter" }
    ]
  }
}
{% endschema %}
