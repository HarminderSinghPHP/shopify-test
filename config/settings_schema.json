[
  {
    "name": "theme_info",
    "theme_name": "Aurora",
    "theme_version": "1.0.0",
    "theme_author": "Custom Build",
	"theme_documentation_url": "https://example.com",
  "theme_support_url": "https://example.com"
  },
  {
    "name": "Favicon",
    "settings": [
      { "type": "image_picker", "id": "favicon", "label": "Favicon", "info": "Will be scaled down to 32 x 32px. To change the logo itself, edit the Header section instead." }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "color_background", "label": "Background", "default": "#FFFFFF" },
      { "type": "color", "id": "color_text", "label": "Text", "default": "#1A1A1A" },
      { "type": "color", "id": "color_accent", "label": "Accent / Buttons", "default": "#1A1A1A" },
      { "type": "color", "id": "color_accent_text", "label": "Button text", "default": "#FFFFFF" },
      { "type": "color", "id": "color_border", "label": "Borders / Lines", "default": "#E5E5E5" },
      { "type": "color", "id": "color_header_bg", "label": "Header background", "default": "#FFFFFF" },
      { "type": "color", "id": "color_footer_bg", "label": "Footer background", "default": "#F5F5F5" },
      { "type": "color", "id": "color_footer_text", "label": "Footer text", "default": "#1A1A1A" },
      { "type": "color", "id": "color_sale", "label": "Sale badge", "default": "#D2402C" },
      { "type": "color", "id": "color_soldout", "label": "Sold out badge", "default": "#8A8A8A" }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "font_heading",
        "label": "Heading font",
        "options": [
          { "value": "'Helvetica Neue', Helvetica, Arial, sans-serif", "label": "Modern sans-serif" },
          { "value": "Georgia, 'Times New Roman', serif", "label": "Classic serif" },
          { "value": "'Trebuchet MS', 'Segoe UI', sans-serif", "label": "Rounded friendly" },
          { "value": "'Courier New', monospace", "label": "Monospace" }
        ],
        "default": "'Helvetica Neue', Helvetica, Arial, sans-serif"
      },
      { "type": "range", "id": "heading_scale", "min": 100, "max": 150, "step": 5, "unit": "%", "label": "Heading size scale", "default": 100 },
      { "type": "range", "id": "heading_letter_spacing", "min": -2, "max": 4, "step": 0.5, "unit": "px", "label": "Heading letter spacing", "default": 0 },
      {
        "type": "select",
        "id": "font_body",
        "label": "Body font",
        "options": [
          { "value": "'Helvetica Neue', Helvetica, Arial, sans-serif", "label": "Modern sans-serif" },
          { "value": "Georgia, 'Times New Roman', serif", "label": "Classic serif" },
          { "value": "'Trebuchet MS', 'Segoe UI', sans-serif", "label": "Rounded friendly" },
          { "value": "'Courier New', monospace", "label": "Monospace" }
        ],
        "default": "'Helvetica Neue', Helvetica, Arial, sans-serif"
      },
      { "type": "range", "id": "body_scale", "min": 90, "max": 120, "step": 5, "unit": "%", "label": "Body size scale", "default": 100 }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      { "type": "range", "id": "page_width", "min": 1000, "max": 1600, "step": 20, "unit": "px", "label": "Page width", "default": 1280 },
      { "type": "range", "id": "spacing_sections", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Space between sections", "default": 48 },
      { "type": "range", "id": "grid_gutter", "min": 8, "max": 40, "step": 2, "unit": "px", "label": "Grid gutter (space between grid items)", "default": 24 }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      {
        "type": "select",
        "id": "button_style",
        "label": "Shape",
        "options": [
          { "value": "square", "label": "Square" },
          { "value": "rounded", "label": "Rounded" },
          { "value": "pill", "label": "Pill" }
        ],
        "default": "rounded"
      },
      { "type": "range", "id": "button_border_thickness", "min": 0, "max": 4, "step": 1, "unit": "px", "label": "Border thickness", "default": 1 },
      { "type": "checkbox", "id": "button_uppercase", "label": "Uppercase text", "default": false },
      { "type": "checkbox", "id": "button_shadow", "label": "Show shadow", "default": false }
    ]
  },
  {
    "name": "Variant pills",
    "settings": [
      {
        "type": "select",
        "id": "variant_pill_shape",
        "label": "Shape",
        "options": [
          { "value": "square", "label": "Square" },
          { "value": "rounded", "label": "Rounded" },
          { "value": "pill", "label": "Pill" }
        ],
        "default": "rounded"
      },
      { "type": "range", "id": "variant_pill_border_thickness", "min": 1, "max": 4, "step": 1, "unit": "px", "label": "Border thickness", "default": 1 }
    ]
  },
  {
    "name": "Inputs",
    "settings": [
      {
        "type": "select",
        "id": "input_shape",
        "label": "Shape",
        "options": [
          { "value": "square", "label": "Square" },
          { "value": "rounded", "label": "Rounded" },
          { "value": "pill", "label": "Pill" }
        ],
        "default": "rounded"
      },
      { "type": "range", "id": "input_border_thickness", "min": 1, "max": 4, "step": 1, "unit": "px", "label": "Border thickness", "default": 1 }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      {
        "type": "select",
        "id": "card_image_ratio",
        "label": "Image ratio",
        "options": [
          { "value": "square", "label": "Square" },
          { "value": "portrait", "label": "Portrait" },
          { "value": "landscape", "label": "Landscape" }
        ],
        "default": "square"
      },
      { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": false },
      { "type": "checkbox", "id": "show_sale_badge", "label": "Show sale badge", "default": true },
      { "type": "checkbox", "id": "card_shadow", "label": "Show shadow", "default": false },
      { "type": "range", "id": "card_border_thickness", "min": 0, "max": 4, "step": 1, "unit": "px", "label": "Border thickness", "default": 0 },
      { "type": "range", "id": "card_corner_radius", "min": 0, "max": 24, "step": 2, "unit": "px", "label": "Corner radius", "default": 8 }
    ]
  },
  {
    "name": "Collection cards",
    "settings": [
      {
        "type": "select",
        "id": "collection_card_image_ratio",
        "label": "Image ratio",
        "options": [
          { "value": "square", "label": "Square" },
          { "value": "portrait", "label": "Portrait" },
          { "value": "landscape", "label": "Landscape" }
        ],
        "default": "square"
      },
      { "type": "range", "id": "collection_card_corner_radius", "min": 0, "max": 24, "step": 2, "unit": "px", "label": "Corner radius", "default": 8 },
      { "type": "checkbox", "id": "collection_card_shadow", "label": "Show shadow", "default": false }
    ]
  },
  {
    "name": "Blog cards",
    "settings": [
      { "type": "checkbox", "id": "blog_card_show_date", "label": "Show date", "default": true },
      { "type": "checkbox", "id": "blog_card_show_excerpt", "label": "Show excerpt", "default": true },
      { "type": "range", "id": "blog_card_corner_radius", "min": 0, "max": 24, "step": 2, "unit": "px", "label": "Corner radius", "default": 8 }
    ]
  },
  {
    "name": "Content containers",
    "settings": [
      { "type": "range", "id": "container_border_thickness", "min": 0, "max": 4, "step": 1, "unit": "px", "label": "Border thickness", "default": 1 },
      { "type": "range", "id": "container_corner_radius", "min": 0, "max": 24, "step": 2, "unit": "px", "label": "Corner radius", "default": 8 },
      { "type": "range", "id": "container_shadow_opacity", "min": 0, "max": 60, "step": 5, "unit": "%", "label": "Shadow opacity", "default": 0 }
    ]
  },
  {
    "name": "Media",
    "settings": [
      { "type": "range", "id": "media_corner_radius", "min": 0, "max": 24, "step": 2, "unit": "px", "label": "Corner radius", "default": 8 },
      { "type": "checkbox", "id": "media_shadow", "label": "Show shadow", "default": false }
    ]
  },
  {
    "name": "Dropdowns and pop-ups",
    "settings": [
      { "type": "range", "id": "popup_border_thickness", "min": 0, "max": 4, "step": 1, "unit": "px", "label": "Border thickness", "default": 1 },
      { "type": "range", "id": "popup_corner_radius", "min": 0, "max": 24, "step": 2, "unit": "px", "label": "Corner radius", "default": 8 },
      { "type": "range", "id": "popup_shadow_opacity", "min": 0, "max": 60, "step": 5, "unit": "%", "label": "Shadow opacity", "default": 15 }
    ]
  },
  {
    "name": "Drawers",
    "settings": [
      { "type": "color", "id": "drawer_background", "label": "Background", "default": "#FFFFFF" },
      { "type": "range", "id": "drawer_border_thickness", "min": 0, "max": 4, "step": 1, "unit": "px", "label": "Border thickness", "default": 0 }
    ]
  },
  {
    "name": "Badges",
    "settings": [
      {
        "type": "select",
        "id": "badge_shape",
        "label": "Shape",
        "options": [
          { "value": "square", "label": "Square" },
          { "value": "rounded", "label": "Rounded" },
          { "value": "pill", "label": "Pill" }
        ],
        "default": "rounded"
      },
      {
        "type": "select",
        "id": "badge_position",
        "label": "Position on cards",
        "options": [
          { "value": "top-left", "label": "Top left" },
          { "value": "top-right", "label": "Top right" },
          { "value": "bottom-left", "label": "Bottom left" },
          { "value": "bottom-right", "label": "Bottom right" }
        ],
        "default": "top-left"
      }
    ]
  },
  {
    "name": "Icons",
    "settings": [
      { "type": "range", "id": "icon_stroke_width", "min": 1, "max": 3, "step": 0.5, "unit": "px", "label": "Stroke thickness", "default": 1.5 }
    ]
  },
  {
    "name": "Brand information",
    "settings": [
      { "type": "image_picker", "id": "brand_image", "label": "Brand image" },
      { "type": "richtext", "id": "brand_description", "label": "Short description" },
      { "type": "text", "id": "brand_headline", "label": "Headline" }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      { "type": "text", "id": "social_facebook", "label": "Facebook URL" },
      { "type": "text", "id": "social_instagram", "label": "Instagram URL" },
      { "type": "text", "id": "social_twitter", "label": "Twitter / X URL" },
      { "type": "text", "id": "social_youtube", "label": "YouTube URL" }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer"
      },
      { "type": "checkbox", "id": "cart_notes", "label": "Enable order notes", "default": true },
      { "type": "header", "content": "Free shipping progress bar" },
      { "type": "checkbox", "id": "enable_free_shipping_bar", "label": "Enable free shipping progress bar", "default": true },
      { "type": "range", "id": "free_shipping_threshold", "min": 0, "max": 300, "step": 5, "unit": "$", "label": "Free shipping amount", "default": 75 },
      { "type": "text", "id": "free_shipping_text_progress", "label": "Progress text", "info": "Use [amount] where the remaining amount should appear.", "default": "You're [amount] away from free shipping!" },
      { "type": "text", "id": "free_shipping_text_complete", "label": "Complete text", "default": "🎉 You've unlocked free shipping!" },
      { "type": "header", "content": "Free gift with discount code" },
      { "type": "checkbox", "id": "enable_gift_with_discount", "label": "Enable free gift with discount code", "default": false },
      { "type": "text", "id": "gift_discount_code", "label": "Discount code that triggers the gift", "info": "Must exactly match a discount code you create in Shopify Admin > Discounts. The gift product itself should be priced at $0 so it's genuinely free once added." },
      { "type": "text", "id": "gift_variant_id", "label": "Gift product Variant ID", "info": "The numeric Variant ID of the free gift product." }
    ]
  },
  {
    "name": "Wishlist, Compare & Quick view",
    "settings": [
      { "type": "header", "content": "Wishlist" },
      { "type": "checkbox", "id": "enable_wishlist", "label": "Enable wishlist", "default": true },
      { "type": "url", "id": "wishlist_page_url", "label": "Wishlist page link", "info": "Create a Page in Shopify Admin, assign it the \u201cpage.wishlist\u201d template, then link to it here (e.g. /pages/wishlist)." },

      { "type": "header", "content": "Compare" },
      { "type": "checkbox", "id": "enable_compare", "label": "Enable compare", "default": true },
      { "type": "range", "id": "compare_max_items", "min": 2, "max": 6, "step": 1, "label": "Max products to compare", "default": 4 },
      { "type": "url", "id": "compare_page_url", "label": "Compare page link", "info": "Create a Page in Shopify Admin, assign it the \u201cpage.compare\u201d template, then link to it here (e.g. /pages/compare)." },

      { "type": "header", "content": "Quick view" },
      { "type": "checkbox", "id": "enable_quick_view", "label": "Enable quick view button on product cards", "default": true }
    ]
  }
]
