{% comment %} Renders a small inline SVG icon. Usage: {% render 'icon', name: 'cart' %} {% endcomment %}
{% case name %}
  {% when 'cart' %}
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
  {% when 'search' %}
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
  {% when 'account' %}
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
  {% when 'menu' %}
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
  {% when 'close' %}
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M18 6L6 18M6 6l12 12"/></svg>
  {% when 'instagram' %}
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/></svg>
  {% when 'facebook' %}
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
  {% when 'twitter' %}
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M23 3a10.9 10.9 0 01-3.14 1.53A4.48 4.48 0 0022.4.36a9 9 0 01-2.85 1.09 4.52 4.52 0 00-7.7 4.13A12.83 12.83 0 011.64 1.15a4.5 4.5 0 001.4 6.03A4.42 4.42 0 011 6.6v.06a4.51 4.51 0 003.63 4.43 4.46 4.46 0 01-2 .08 4.52 4.52 0 004.22 3.14A9.06 9.06 0 011 16.4a12.75 12.75 0 006.92 2"/></svg>
  {% when 'youtube' %}
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><rect x="2" y="5" width="20" height="14" rx="4"/><path d="M10 9l6 3-6 3z"/></svg>
  {% when 'shield-check' %}
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
  {% when 'shield-dollar' %}
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v8M14.5 9.5c0-1-1-1.5-2.5-1.5s-2.5.6-2.5 1.7c0 2.3 5 1 5 3.3 0 1.1-1 1.7-2.5 1.7s-2.5-.5-2.5-1.5"/></svg>
  {% when 'shield-lock' %}
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><rect x="9.5" y="11" width="5" height="4" rx="0.8"/><path d="M10.3 11V9.6a1.7 1.7 0 013.4 0V11"/></svg>
  {% when 'trash' %}
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M3 6h18"/><path d="M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
  {% when 'pay-visa' %}
    <svg width="38" height="24" viewBox="0 0 38 24"><rect x="0.5" y="0.5" width="37" height="23" rx="3" fill="#fff" stroke="#e0e0e0"/><text x="19" y="16" font-family="Arial, sans-serif" font-size="9" font-weight="700" fill="#1a1f71" text-anchor="middle">VISA</text></svg>
  {% when 'pay-mastercard' %}
    <svg width="38" height="24" viewBox="0 0 38 24"><rect x="0.5" y="0.5" width="37" height="23" rx="3" fill="#fff" stroke="#e0e0e0"/><circle cx="16" cy="12" r="6.5" fill="#eb001b"/><circle cx="24" cy="12" r="6.5" fill="#f79e1b" fill-opacity="0.85"/></svg>
  {% when 'pay-amex' %}
    <svg width="38" height="24" viewBox="0 0 38 24"><rect x="0.5" y="0.5" width="37" height="23" rx="3" fill="#016fd0" stroke="#e0e0e0"/><text x="19" y="16" font-family="Arial, sans-serif" font-size="7.5" font-weight="700" fill="#fff" text-anchor="middle">AMEX</text></svg>
  {% when 'pay-paypal' %}
    <svg width="38" height="24" viewBox="0 0 38 24"><rect x="0.5" y="0.5" width="37" height="23" rx="3" fill="#fff" stroke="#e0e0e0"/><text x="19" y="16" font-family="Arial, sans-serif" font-size="7" font-weight="700" font-style="italic" fill="#003087" text-anchor="middle">PayPal</text></svg>
  {% when 'pay-applepay' %}
    <svg width="38" height="24" viewBox="0 0 38 24"><rect x="0.5" y="0.5" width="37" height="23" rx="3" fill="#000" stroke="#e0e0e0"/><text x="19" y="16" font-family="Arial, sans-serif" font-size="7.5" font-weight="600" fill="#fff" text-anchor="middle">Pay</text></svg>
  {% when 'urgency-clock' %}
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="4" y="3" width="16" height="4" rx="1"/><path d="M6 7v3a6 6 0 0012 0V7"/><path d="M6 21v-3a6 6 0 0112-0v3"/><path d="M12 12v2l1.3 1.3"/></svg>
  {% when 'urgency-box' %}
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M21 8l-9-5-9 5 9 5 9-5z"/><path d="M3 8v8l9 5 9-5V8"/><path d="M12 13v8"/></svg>
  {% when 'urgency-target' %}
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1.2" fill="currentColor"/></svg>
  {% when 'chevron-right' %}
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M9 6l6 6-6 6"/></svg>
  {% when 'chevron-left' %}
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M15 6l-6 6 6 6"/></svg>
  {% when 'heart' %}
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M20.8 4.6a5.5 5.5 0 00-7.8 0L12 5.6l-1-1a5.5 5.5 0 00-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 000-7.8z"/></svg>
  {% when 'compare' %}
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M7 3v18M17 3v18M3 8h8M13 16h8"/></svg>
  {% when 'eye' %}
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="var(--icon-stroke-width, 1.5)"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z"/><circle cx="12" cy="12" r="3"/></svg>
{% endcase %}
