<div class="dynamic-product-tab-card">
  <div class="dynamic-product-tab-card__image-wrap">

    {% if product.compare_at_price > product.price %}
      <span class="dynamic-product-tab-card__sale-badge">
        Sale
      </span>
    {% endif %}

    <div class="dynamic-product-tab-card__actions">
      <button
        type="button"
        class="dynamic-product-tab-card__icon-button"
        aria-label="Add {{ product.title | escape }} to wishlist"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1.1-1.1a5.5 5.5 0 0 0-7.8 7.8l1.1 1.1L12 21l7.8-7.5 1.1-1.1a5.5 5.5 0 0 0-.1-7.8z"></path>
        </svg>
      </button>

      <a
        href="{{ product.url }}"
        class="dynamic-product-tab-card__icon-button"
        aria-label="View {{ product.title | escape }}"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7S1 12 1 12z"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
      </a>
    </div>

    <a
      href="{{ product.url }}"
      class="dynamic-product-tab-card__image-ratio"
    >
      {% if product.featured_image != blank %}
        {{
          product.featured_image
          | image_url: width: 800
          | image_tag:
            loading: 'lazy',
            widths: '240, 360, 480, 600, 800',
            sizes: '(max-width: 749px) 50vw, 20vw',
            class: 'dynamic-product-tab-card__image',
            alt: product.featured_image.alt | default: product.title
        }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'dynamic-product-tab-card__placeholder' }}
      {% endif %}
    </a>

    {% if product.has_only_default_variant and product.available %}
      <form method="post" action="{{ routes.cart_add_url }}">
        <input
          type="hidden"
          name="id"
          value="{{ product.selected_or_first_available_variant.id }}"
        >

        <button
          type="submit"
          class="dynamic-product-tab-card__button"
        >
          Add to cart
        </button>
      </form>
    {% else %}
      <a
        href="{{ product.url }}"
        class="dynamic-product-tab-card__button"
      >
        Choose options
      </a>
    {% endif %}
  </div>

  <div class="dynamic-product-tab-card__info">

    {% if product.vendor != blank %}
      <div class="dynamic-product-tab-card__vendor">
        {{ product.vendor }}
      </div>
    {% endif %}

    <a
      href="{{ product.url }}"
      class="dynamic-product-tab-card__title"
    >
      {{ product.title }}
    </a>

    <div class="dynamic-product-tab-card__price">
      {% if product.price_varies %}
        <span>
          From {{ product.price_min | money }}
        </span>
      {% elsif product.compare_at_price > product.price %}
        <span class="dynamic-product-tab-card__compare-price">
          {{ product.compare_at_price | money }}
        </span>

        <span class="dynamic-product-tab-card__sale-price">
          {{ product.price | money }}
        </span>
      {% else %}
        <span>
          {{ product.price | money }}
        </span>
      {% endif %}
    </div>
  </div>
</div>