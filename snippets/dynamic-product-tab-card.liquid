<div class="dynamic-product-tab-card">
  <div class="dynamic-product-tab-card__image-wrap">

    {% if product.compare_at_price > product.price %}
      <span class="dynamic-product-tab-card__sale-badge">
        Sale
      </span>
    {% endif %}

    {% if settings.enable_wishlist or settings.enable_compare %}
      <div class="dynamic-product-tab-card__actions product-card-icon-actions">
        {% if settings.enable_wishlist %}
          <button
            type="button"
            class="dynamic-product-tab-card__icon-button card-icon-btn wishlist-toggle"
            data-wishlist-toggle
            data-product-id="{{ product.id }}"
            data-product-handle="{{ product.handle }}"
            data-product-title="{{ product.title | escape }}"
            data-product-price="{{ product.price }}"
            data-product-image="{{ product.featured_image | image_url: width: 400 }}"
            data-product-url="{{ product.url }}"
            aria-label="Add {{ product.title | escape }} to wishlist"
            aria-pressed="false"
          >
            {% render 'icon', name: 'heart' %}
          </button>
        {% endif %}

        {% if settings.enable_compare %}
          <button
            type="button"
            class="dynamic-product-tab-card__icon-button card-icon-btn compare-toggle"
            data-compare-toggle
            data-product-id="{{ product.id }}"
            data-product-handle="{{ product.handle }}"
            data-product-title="{{ product.title | escape }}"
            data-product-price="{{ product.price }}"
            data-product-image="{{ product.featured_image | image_url: width: 400 }}"
            data-product-url="{{ product.url }}"
            data-product-vendor="{{ product.vendor | escape }}"
            aria-label="Add {{ product.title | escape }} to compare"
            aria-pressed="false"
          >
            {% render 'icon', name: 'compare' %}
          </button>
        {% endif %}
      </div>
    {% endif %}

    <a
      href="{{ product.url }}"
      class="dynamic-product-tab-card__image-ratio"
    >
      {% if product.featured_image != blank %}
        {{
          product.featured_image
          | image_url: width: 800
          | image_tag:
            loading: 'lazy',
            widths: '240, 360, 480, 600, 800',
            sizes: '(max-width: 749px) 50vw, 20vw',
            class: 'dynamic-product-tab-card__image',
            alt: product.featured_image.alt | default: product.title
        }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'dynamic-product-tab-card__placeholder' }}
      {% endif %}
    </a>

    {% if settings.enable_quick_view %}
      <button
        type="button"
        class="dynamic-product-tab-card__quick-view quick-view-btn"
        data-quick-view
        data-drawer-open="quick-view-modal"
        data-product-handle="{{ product.handle }}"
      >
        {% render 'icon', name: 'eye' %}
        <span>Quick view</span>
      </button>
    {% endif %}

    {% if product.has_only_default_variant and product.available %}
      <form method="post" action="{{ routes.cart_add_url }}">
        <input
          type="hidden"
          name="id"
          value="{{ product.selected_or_first_available_variant.id }}"
        >

        <button
          type="submit"
          class="dynamic-product-tab-card__button"
        >
          Add to cart
        </button>
      </form>
    {% else %}
      <a
        href="{{ product.url }}"
        class="dynamic-product-tab-card__button"
      >
        Choose options
      </a>
    {% endif %}
  </div>

  <div class="dynamic-product-tab-card__info">

    {% if product.vendor != blank %}
      <div class="dynamic-product-tab-card__vendor">
        {{ product.vendor }}
      </div>
    {% endif %}

    <a
      href="{{ product.url }}"
      class="dynamic-product-tab-card__title"
    >
      {{ product.title }}
    </a>

    <div class="dynamic-product-tab-card__price">
      {% if product.price_varies %}
        <span>
          From {{ product.price_min | money }}
        </span>
      {% elsif product.compare_at_price > product.price %}
        <span class="dynamic-product-tab-card__compare-price">
          {{ product.compare_at_price | money }}
        </span>

        <span class="dynamic-product-tab-card__sale-price">
          {{ product.price | money }}
        </span>
      {% else %}
        <span>
          {{ product.price | money }}
        </span>
      {% endif %}
    </div>
  </div>
</div>