<div id="showResortForm">
    <h3>Custom Features:</h3>
    
    <form method="post" action="/contact">
        <div class="form-group">
            <textarea class="form-control" name="contact[resort_description]" id="resort_description" rows="6" placeholder="How would you like us to customize the sauna for you?"></textarea>
            <div id="resort_descriptionErr"></div>
        </div>
        <div class="form-group">
            <input type="text" class="form-control input-box-height" name="contact[resort_name]" id="resort_name" placeholder="Full Name" required>
            <div id="resort_nameErr"></div>
        </div>
        <div class="form-group">
            <input type="text" class="form-control input-box-height" name="contact[resort_phone1]" id="resort_phone1" placeholder="123-456-7890 - Phone Number" maxlength="12" required>
            <div id="resort_phone1Err"></div>
        </div>
        <div class="form-group">
            <input type="text" class="form-control input-box-height" name="contact[resort_bkp_phone2]" id="resort_bkp_phone2" placeholder="123-456-7890 - Backup Phone Number" maxlength="12">
            <div id="resort_bkp_phone2Err"></div>
        </div>
        <div class="form-group">
            <input type="email" class="form-control input-box-height" name="contact[email]" id="resort_email" placeholder="Email" required>
            <div id="resort_emailErr"></div>
        </div>
        <div class="form-group">
            <button type="submit" class="btn btn-lg btn-xl resort-featers-button" id="resort_custom_form">Send</button>
            <div class="row">
                <div class="col-md-12">
                    <div id="resort-succesmsg" style="color: green;"></div>
                </div>
            </div>
        </div>
    </form>
</div>