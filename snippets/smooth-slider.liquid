<div id="gallery-wrapper">
  <div id="thumbnails-wrapper">
    <div id="thumbnails">
      {% for image in product.media %}
        <img src="{{ image | image_url }}" alt="Thumb {{ forloop.index }}" data-index="{{ forloop.index0 }}">
      {% endfor %}
    </div>
    <div id="thumb-gradient"></div>
  </div>
 
  <div id="slider">
    {% for image in product.media %}
      <img src="{{ image | image_url }}" alt="Slide {{ forloop.index }}" class="{% if forloop.first %}active{% endif %}">
    {% endfor %}
    
    <button id="prev" class="slider-arrow">&#10094;</button>
    <button id="next" class="slider-arrow">&#10095;</button>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const slides = document.querySelectorAll('#slider img');
  const thumbnails = document.querySelectorAll('#thumbnails img');
  const prevBtn = document.getElementById('prev');
  const nextBtn = document.getElementById('next');
  const thumbPrev = document.getElementById('thumb-prev');
  const thumbNext = document.getElementById('thumb-next');
  const thumbContainer = document.getElementById('thumbnails');

  let currentIndex = 0;

  function showSlide(index) {
    slides.forEach((img, i) => {
      img.classList.toggle('active', i === index);
    });
    thumbnails.forEach((thumb, i) => {
      thumb.classList.toggle('selected', i === index);
    });
    currentIndex = index;
    thumbnails[index].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  prevBtn.addEventListener('click', (e) => {
    e.preventDefault();
    if (currentIndex > 0) showSlide(currentIndex - 1);
  });

  nextBtn.addEventListener('click', (e) => { 
    e.preventDefault();
    if (currentIndex < slides.length - 1) showSlide(currentIndex + 1);
  });

  thumbnails.forEach((thumb, i) => {
    thumb.addEventListener('click', () => showSlide(i));
  });

  thumbPrev.addEventListener('click', (e) => {
    e.preventDefault();
    thumbContainer.scrollBy({ top: -100, behavior: 'smooth' });
  });

  thumbNext.addEventListener('click', (e) => {
    e.preventDefault();
    thumbContainer.scrollBy({ top: 100, behavior: 'smooth' });
  });

  showSlide(currentIndex);
});
</script>
