<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="canonical" href="{{ canonical_url }}">
  {% if settings.favicon %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32 }}">
  {% endif %}

  <title>
    {{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
  <script>window.themeMoneyFormat = {{ shop.money_format | json }};</script>

  <style>
    :root {
      --color-background: {{ settings.color_background }};
      --color-text: {{ settings.color_text }};
      --color-accent: {{ settings.color_accent }};
      --color-accent-text: {{ settings.color_accent_text }};
      --color-border: {{ settings.color_border }};
      --color-header-bg: {{ settings.color_header_bg }};
      --color-footer-bg: {{ settings.color_footer_bg }};
      --color-footer-text: {{ settings.color_footer_text }};
      --color-sale: {{ settings.color_sale }};
      --color-soldout: {{ settings.color_soldout }};
      --drawer-background: {{ settings.drawer_background }};

      --page-width: {{ settings.page_width }}px;
      --spacing-sections: {{ settings.spacing_sections }}px;
      --grid-gutter: {{ settings.grid_gutter }}px;

      --heading-scale: {{ settings.heading_scale | divided_by: 100.0 }};
      --heading-letter-spacing: {{ settings.heading_letter_spacing }}px;
      --body-scale: {{ settings.body_scale | divided_by: 100.0 }};

      --radius: {% if settings.button_style == 'square' %}0px{% elsif settings.button_style == 'pill' %}999px{% else %}8px{% endif %};
      --button-border-width: {{ settings.button_border_thickness }}px;
      --button-text-transform: {% if settings.button_uppercase %}uppercase{% else %}none{% endif %};
      --button-shadow: {% if settings.button_shadow %}0 2px 6px rgba(0,0,0,0.15){% else %}none{% endif %};

      --variant-pill-radius: {% if settings.variant_pill_shape == 'square' %}0px{% elsif settings.variant_pill_shape == 'pill' %}999px{% else %}8px{% endif %};
      --variant-pill-border-width: {{ settings.variant_pill_border_thickness }}px;

      --input-radius: {% if settings.input_shape == 'square' %}0px{% elsif settings.input_shape == 'pill' %}999px{% else %}8px{% endif %};
      --input-border-width: {{ settings.input_border_thickness }}px;

      --card-radius: {{ settings.card_corner_radius }}px;
      --card-border-width: {{ settings.card_border_thickness }}px;
      --card-shadow: {% if settings.card_shadow %}0 4px 12px rgba(0,0,0,0.1){% else %}none{% endif %};

      --collection-card-radius: {{ settings.collection_card_corner_radius }}px;
      --collection-card-shadow: {% if settings.collection_card_shadow %}0 4px 12px rgba(0,0,0,0.1){% else %}none{% endif %};
      --collection-card-ratio: {% if settings.collection_card_image_ratio == 'portrait' %}3/4{% elsif settings.collection_card_image_ratio == 'landscape' %}4/3{% else %}1/1{% endif %};

      --blog-card-radius: {{ settings.blog_card_corner_radius }}px;

      --container-radius: {{ settings.container_corner_radius }}px;
      --container-border-width: {{ settings.container_border_thickness }}px;
      --container-shadow: {% if settings.container_shadow_opacity > 0 %}0 4px 14px rgba(0,0,0,{{ settings.container_shadow_opacity | divided_by: 100.0 }}){% else %}none{% endif %};

      --media-radius: {{ settings.media_corner_radius }}px;
      --media-shadow: {% if settings.media_shadow %}0 4px 12px rgba(0,0,0,0.12){% else %}none{% endif %};

      --popup-radius: {{ settings.popup_corner_radius }}px;
      --popup-border-width: {{ settings.popup_border_thickness }}px;
      --popup-shadow: {% if settings.popup_shadow_opacity > 0 %}0 8px 24px rgba(0,0,0,{{ settings.popup_shadow_opacity | divided_by: 100.0 }}){% else %}none{% endif %};

      --drawer-border-width: {{ settings.drawer_border_thickness }}px;

      --badge-radius: {% if settings.badge_shape == 'square' %}0px{% elsif settings.badge_shape == 'pill' %}999px{% else %}4px{% endif %};

      --icon-stroke-width: {{ settings.icon_stroke_width }};
    }
    body { font-family: {{ settings.font_body }}; font-size: calc(1rem * var(--body-scale)); }
    h1, h2, h3, h4, h5, h6, .heading-font { font-family: {{ settings.font_heading }}; letter-spacing: var(--heading-letter-spacing); }
  </style>
</head>
<body class="cart-type-{{ settings.cart_type }} badge-position-{{ settings.badge_position }}">

  <a class="skip-to-content" href="#MainContent">Skip to content</a>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {% if settings.cart_type == 'drawer' %}
    {% section 'cart-drawer' %}
  {% endif %}

  {% if settings.enable_quick_view %}
    {% render 'quick-view-modal' %}
  {% endif %}
  
  

  {% section 'color-swatches' %}
  <script>
    (function () {
      var el = document.getElementById('theme-color-swatches-data');
      if (!el) return;
      try {
        window.themeColorSwatches = JSON.parse(el.textContent);
      } catch (e) {
        window.themeColorSwatches = {};
      }
    })();
  </script>

  
  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
