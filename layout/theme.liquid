	const featureTexts = document.querySelectorAll('.feature-h-text');

featureTexts.forEach(featureText => {
  featureText.addEventListener('click', function() {
    // Remove 'collapsed' class from all .feature-h-text elements
    featureTexts.forEach(el => el.classList.remove('collapsed'));

    // Add 'collapsed' class to the clicked .feature-h-text element
