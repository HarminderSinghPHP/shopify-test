    <script>
        $("#popupReviewMsg").on('show.bs.modal', function(ev) {
            var msg = $(ev.relatedTarget).data('review_msg');
            var location = $(ev.relatedTarget).data('location');
            var name = $(ev.relatedTarget).data('name');
            var order = $(ev.relatedTarget).data('order');
            var rating = $(ev.relatedTarget).data('rating');
            $("#msg").html(msg);
            $("#location").html(location);
            $("#name").html(name);
            $("#order_again").html(order);
            var html_content = '';
            for (i = 0; i < rating; i++) {
                html_content += '<i class="fa fa-star b-c"></i>';
            }
            for (i = (5 - rating); i > 0; i--) {
                html_content += '<i class="fa fa-star-o b-c"></i>';
            }
            $("#rating_name").html(html_content);

        });
    </script> 
